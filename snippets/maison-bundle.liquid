{%- doc -%}
  Renders the Maison Bundle purchase widget with single purchase / subscribe & save tabs,
  AlpineJS-powered variant swatch selection, selling plan support, and quantity multiplier.

  @param {object} product_resource - The product object.
  @param {object} block - The block object.
  @param {object} section - The section object.
{%- enddoc -%}

{%- liquid
  assign save_percent = block.settings.save_percent | default: 15
  assign low_stock_text = block.settings.low_stock_text | default: 'Low stock: Only few items left'
  assign bogo_text = block.settings.bogo_badge_text | default: 'BOGO SALE'
  assign single_units = block.settings.single_units | default: 2
  assign variant = product_resource.selected_or_first_available_variant
  assign single_price = variant.price | times: single_units | money
  assign single_compare_price = nil
  if variant.compare_at_price and variant.compare_at_price > variant.price
    assign single_compare_price = variant.compare_at_price | times: single_units | money
  endif
  assign trust_1 = block.settings.trust_badge_1
  assign trust_2 = block.settings.trust_badge_2
  assign trust_3 = block.settings.trust_badge_3
  assign find_shade_url = block.settings.find_shade_url | default: '#open-quiz-tools/perfect-product-finder/discover-your-perfect-shade'
  assign tier_count = block.settings.tier_count | default: 3
  assign show_single_tiers = block.settings.show_single_tiers | default: false
  assign bundle_post_atc_upsell = block.settings.bundle_post_atc_upsell

  assign sub_benefit_1 = block.settings.sub_benefit_1 | default: 'Save <strong>[save_percent]%</strong> on all deliveries' | replace: '[save_percent]', save_percent
  assign sub_benefit_2 = block.settings.sub_benefit_2 | default: 'No commitment - modify or cancel anytime'
  assign sub_benefit_3 = block.settings.sub_benefit_3 | default: 'Free shipping, always'
  assign sub_benefit_4 = block.settings.sub_benefit_4 | default: 'Out of stock protection for consistent result'

  assign unit_singular = block.settings.unit_label_singular | default: 'bottle'
  assign unit_plural = block.settings.unit_label_plural | default: 'bottles'
  assign per_label = block.settings.per_label | default: '/bottle'
  assign best_value_text = block.settings.best_value_text | default: 'Best Value'
  assign save_badge_format = block.settings.save_badge_format | default: 'SAVE [percent]%' | replace: '[percent]', save_percent
  assign choose_qty_label = block.settings.choose_qty_label | default: 'Choose your quantity'
  assign units_label = block.settings.units_label | default: 'Units'
  assign find_shade_text = block.settings.find_shade_text | default: 'Find your shade'
  assign shade_label = block.settings.shade_label | default: 'Shade'
  assign atc_button_text = block.settings.atc_button_text | default: 'ADD TO CART'
  assign atc_loading_text = block.settings.atc_loading_text | default: 'ADDING...'
  assign free_label = block.settings.free_label | default: 'FREE'
  assign delivery_prefix = block.settings.delivery_prefix | default: 'Delivered every'
  assign month_singular = block.settings.month_singular | default: 'month'
  assign month_plural = block.settings.month_plural | default: 'months'
-%}

<script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>

<div
  class="maison-bundle"
  x-data="maisonBundle()"
  x-cloak
  data-block-id="{{ block.id }}"
  {{ block.shopify_attributes }}
>
  <!-- Low Stock -->
  {% if block.settings.show_low_stock %}
    <div class="mb-low-stock">
      <span class="mb-low-stock__dot"></span>
      {{ low_stock_text }}
    </div>
  {% endif %}

  <!-- Purchase Type Tabs -->
  <div class="mb-tab-container">
    <div class="mb-tab-slider" :class="{ 'mb-tab-slider--right': tab === 'subscribe' }"></div>
    <button
      class="mb-tab-btn"
      :class="{ 'mb-tab-btn--active': tab === 'single' }"
      @click="switchTab('single')"
      type="button"
    >
      {{ block.settings.single_tab_label | default: 'Single Purchase' }}
    </button>
    <button
      class="mb-tab-btn"
      :class="{ 'mb-tab-btn--active': tab === 'subscribe' }"
      @click="switchTab('subscribe')"
      type="button"
    >
      {{ block.settings.subscribe_tab_label | default: 'Subscribe & Save' }}
      <span class="mb-tab-save-badge">{{ save_badge_format }}</span>
    </button>
  </div>

  <!-- PANELS -->
  <div class="mb-panels-container">

    <!-- SINGLE PURCHASE PANEL -->
    <div class="mb-tab-panel" :class="{ 'mb-tab-panel--hidden': tab !== 'single' }">

      {% if show_single_tiers %}
        <div class="mb-sub-section-label">{{ choose_qty_label }}</div>
        <div class="mb-qty-selector">
          <template x-for="(opt, i) in singleOptions" :key="'single-qty-' + i">
            <div
              class="mb-qty-option"
              :class="{ 'mb-qty-option--selected': singleQty === i }"
              @click="selectSingleQty(i)"
            >
              <div class="mb-qty-option__left">
                <span class="mb-qty-option__text" x-text="opt.qty + ' ' + (opt.qty === 1 ? unitSingular : unitPlural)"></span>
                <span class="mb-qty-option__discount" x-show="opt.free > 0" x-text="opt.free + ' ' + freeLabel"></span>
              </div>
              <div class="mb-qty-option__right">
                <span class="mb-qty-option__compare" x-show="opt.originalPrice > 0" x-text="formatMoney(opt.originalPrice)"></span>
                <span class="mb-qty-option__price" x-text="formatMoney(opt.price)"></span>
                <span class="mb-qty-option__per">{{ per_label }}</span>
              </div>
              <span class="mb-qty-option__best-value" x-show="opt.best">{{ best_value_text }}</span>
            </div>
          </template>
        </div>
      {% else %}
        <div class="mb-qty-card mb-qty-card--selected">
          <div class="mb-qty-card__header">
            <span class="mb-qty-card__units">{{ single_units }} {{ units_label }}</span>
            {% if bogo_text != blank %}
              <span class="mb-bogo-badge">{{ bogo_text }}</span>
            {% endif %}
          </div>
          <div class="mb-qty-card__pricing">
            {% if product_resource.compare_at_price > product_resource.price %}
              <span class="mb-price-old">{{ product_resource.compare_at_price | money }}</span>
            {% endif %}
            <span class="mb-price-new">{{ product_resource.price | money }}</span>
          </div>
        </div>
      {% endif %}

      {% if find_shade_url != blank %}
        <div class="mb-delivery-row mb-delivery-row--end">
          <a class="mb-find-shade" href="{{ find_shade_url }}">{{ find_shade_text }}</a>
        </div>
      {% endif %}

      <div class="mb-shade-grid">
        {% if show_single_tiers %}
          <template x-for="n in singleOptions[singleQty].qty" :key="'single-shade-' + n">
            <div class="mb-shade-row mb-animate-in">
              <div class="mb-shade-label">
                <div>
                  <span x-text="singleOptions[singleQty].qty > 1 ? shadeLabel + ' ' + n + ': ' : shadeLabel + ': '"></span>
                  <strong x-text="getVariantName(singleShades[n - 1] ?? 1)"></strong>
                </div>
              </div>
              <div class="mb-swatches">
                <template x-for="(variant, idx) in variants" :key="'single-sw-' + n + '-' + idx">
                  <div
                    class="mb-swatch"
                    :class="{ 'mb-swatch--selected': (singleShades[n - 1] ?? 1) === idx }"
                    :style="'background:' + variant.swatchColor"
                    @click="setSingleShade(n - 1, idx)"
                  ></div>
                </template>
              </div>
            </div>
          </template>
        {% else %}
          {% for i in (1..single_units) %}
            <div class="mb-shade-row">
              <div class="mb-shade-label">
                <div>
                  <span>{% if single_units > 1 %}{{ shade_label }} {{ i }}:{% else %}{{ shade_label }}:{% endif %}</span>
                  <strong x-text="getVariantName(singleShades[{{ i | minus: 1 }}])"></strong>
                </div>
              </div>
              <div class="mb-swatches">
                <template x-for="(variant, idx) in variants" :key="'single-{{ i }}-' + idx">
                  <div
                    class="mb-swatch"
                    :class="{ 'mb-swatch--selected': singleShades[{{ i | minus: 1 }}] === idx }"
                    :style="'background:' + variant.swatchColor"
                    @click="setSingleShade({{ i | minus: 1 }}, idx)"
                  ></div>
                </template>
              </div>
            </div>
          {% endfor %}
        {% endif %}
      </div>

      <form action="{{ routes.cart_add_url }}" method="post" @submit.prevent="addToCartSingle()">
        <button type="submit" class="mb-add-to-cart" :disabled="loading">
          <span x-show="!loading">{{ atc_button_text }}</span>
          <span x-show="loading">{{ atc_loading_text }}</span>
        </button>
      </form>
    </div>

    <!-- SUBSCRIBE & SAVE PANEL -->
    <div class="mb-tab-panel" :class="{ 'mb-tab-panel--hidden': tab !== 'subscribe' }">

      <!-- Subscribe Benefits -->
      {% if sub_benefit_1 != blank or sub_benefit_2 != blank or sub_benefit_3 != blank or sub_benefit_4 != blank %}
        <div class="mb-sub-benefits">
          <div class="mb-sub-benefits__grid">
            {% if sub_benefit_1 != blank %}
              <div class="mb-sub-benefit">
                {% if block.settings.sub_benefit_icon_1 %}
                  <img class="mb-sub-benefit__check" src="{{ block.settings.sub_benefit_icon_1 | image_url: width: 32 }}" alt="" width="16" height="16" loading="lazy">
                {% else %}
                  <svg class="mb-sub-benefit__check" width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8.5l3.5 3.5L13 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                {% endif %}
                <span>{{ sub_benefit_1 }}</span>
              </div>
            {% endif %}
            {% if sub_benefit_2 != blank %}
              <div class="mb-sub-benefit">
                {% if block.settings.sub_benefit_icon_2 %}
                  <img class="mb-sub-benefit__check" src="{{ block.settings.sub_benefit_icon_2 | image_url: width: 32 }}" alt="" width="16" height="16" loading="lazy">
                {% else %}
                  <svg class="mb-sub-benefit__check" width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8.5l3.5 3.5L13 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                {% endif %}
                <span>{{ sub_benefit_2 }}</span>
              </div>
            {% endif %}
            {% if sub_benefit_3 != blank %}
              <div class="mb-sub-benefit">
                {% if block.settings.sub_benefit_icon_3 %}
                  <img class="mb-sub-benefit__check" src="{{ block.settings.sub_benefit_icon_3 | image_url: width: 32 }}" alt="" width="16" height="16" loading="lazy">
                {% else %}
                  <svg class="mb-sub-benefit__check" width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8.5l3.5 3.5L13 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                {% endif %}
                <span>{{ sub_benefit_3 }}</span>
              </div>
            {% endif %}
            {% if sub_benefit_4 != blank %}
              <div class="mb-sub-benefit">
                {% if block.settings.sub_benefit_icon_4 %}
                  <img class="mb-sub-benefit__check" src="{{ block.settings.sub_benefit_icon_4 | image_url: width: 32 }}" alt="" width="16" height="16" loading="lazy">
                {% else %}
                  <svg class="mb-sub-benefit__check" width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8.5l3.5 3.5L13 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                {% endif %}
                <span>{{ sub_benefit_4 }}</span>
              </div>
            {% endif %}
          </div>
        </div>
      {% endif %}

      <div class="mb-sub-section-label">{{ choose_qty_label }}</div>
      <div class="mb-qty-selector">
        <template x-for="(opt, i) in subOptions" :key="'sub-qty-' + i">
          <div
            class="mb-qty-option"
            :class="{ 'mb-qty-option--selected': subQty === i }"
            @click="selectSubQty(i)"
          >
            <div class="mb-qty-option__left">
              <span class="mb-qty-option__text" x-text="opt.qty + ' ' + (opt.qty === 1 ? unitSingular : unitPlural)"></span>
              <span class="mb-qty-option__discount" x-show="opt.free > 0" x-text="opt.free + ' ' + freeLabel"></span>
              <span class="mb-qty-option__discount" x-show="opt.free === 0 && opt.save > 0" x-text="'-' + opt.save + '%'"></span>
            </div>
            <div class="mb-qty-option__right">
              <span class="mb-qty-option__compare" x-text="formatMoney(opt.originalPrice)"></span>
              <span class="mb-qty-option__price" x-text="formatMoney(opt.price)"></span>
              <span class="mb-qty-option__per">{{ per_label }}</span>
            </div>
            <span class="mb-qty-option__best-value" x-show="opt.best">{{ best_value_text }}</span>
          </div>
        </template>
      </div>

      <!-- Delivery Note + Find Your Shade -->
      <div class="mb-delivery-row">
        <div class="mb-delivery-note">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
          </svg>
          <span>{{ delivery_prefix }} <strong x-text="subOptions[subQty].deliveryMonths + (subOptions[subQty].deliveryMonths === 1 ? ' ' + monthSingular : ' ' + monthPlural)"></strong></span>
        </div>
        {% if find_shade_url != blank %}
          <a class="mb-find-shade" href="{{ find_shade_url }}">{{ find_shade_text }}</a>
        {% endif %}
      </div>

      <!-- Shade selectors for subscribe -->
      <div class="mb-shade-grid">
        <template x-for="n in subOptions[subQty].qty" :key="'sub-shade-' + n">
          <div class="mb-shade-row mb-animate-in">
            <div class="mb-shade-label">
              <div>
                <span x-text="subOptions[subQty].qty > 1 ? shadeLabel + ' ' + n + ': ' : shadeLabel + ': '"></span>
                <strong x-text="getVariantName(subShades[n - 1] ?? 0)"></strong>
              </div>
            </div>
            <div class="mb-swatches">
              <template x-for="(variant, idx) in variants" :key="'sub-sw-' + n + '-' + idx">
                <div
                  class="mb-swatch"
                  :class="{ 'mb-swatch--selected': (subShades[n - 1] ?? 0) === idx }"
                  :style="'background:' + variant.swatchColor"
                  @click="setSubShade(n - 1, idx)"
                ></div>
              </template>
            </div>
          </div>
        </template>
      </div>

      <form action="{{ routes.cart_add_url }}" method="post" @submit.prevent="addToCartSubscribe()">
        <button type="submit" class="mb-add-to-cart" :disabled="loading">
          <span x-show="!loading">{{ atc_button_text }}</span>
          <span x-show="loading">{{ atc_loading_text }}</span>
        </button>
      </form>
    </div>

  </div>

  <!-- USPs (stacked vertically) -->
  {% if trust_1 != blank or trust_2 != blank or trust_3 != blank %}
    <div class="mb-trust-badges">
      {% if trust_1 != blank %}
        <div class="mb-trust-badge">
          {% if block.settings.trust_badge_icon_1 %}
            <img class="mb-trust-badge__icon" src="{{ block.settings.trust_badge_icon_1 | image_url: width: 32 }}" alt="" width="16" height="16" loading="lazy">
          {% else %}
            <svg class="mb-trust-badge__icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10"/>
            </svg>
          {% endif %}
          {{ trust_1 }}
        </div>
      {% endif %}
      {% if trust_2 != blank %}
        <div class="mb-trust-badge">
          {% if block.settings.trust_badge_icon_2 %}
            <img class="mb-trust-badge__icon" src="{{ block.settings.trust_badge_icon_2 | image_url: width: 32 }}" alt="" width="16" height="16" loading="lazy">
          {% else %}
            <svg class="mb-trust-badge__icon" width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 8.5l3.5 3.5L13 5"/>
            </svg>
          {% endif %}
          {{ trust_2 }}
        </div>
      {% endif %}
      {% if trust_3 != blank %}
        <div class="mb-trust-badge">
          {% if block.settings.trust_badge_icon_3 %}
            <img class="mb-trust-badge__icon" src="{{ block.settings.trust_badge_icon_3 | image_url: width: 32 }}" alt="" width="16" height="16" loading="lazy">
          {% else %}
            <svg class="mb-trust-badge__icon" width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 8.5l3.5 3.5L13 5"/>
            </svg>
          {% endif %}
          {{ trust_3 }}
        </div>
      {% endif %}
    </div>
  {% endif %}
</div>

<script>
  function maisonBundle() {
    // Shopify's `product | json` filter now returns only the product handle,
    // so we build the variant payload ourselves with only the fields we need.
    const productData = {
      variants: [
        {%- for v in product_resource.variants -%}
          {
            id: {{ v.id }},
            title: {{ v.title | json }},
            option1: {{ v.option1 | json }},
            available: {{ v.available | json }},
            price: {{ v.price | default: 0 }},
            compare_at_price: {{ v.compare_at_price | default: 0 }},
            featured_image: {{ v.featured_image | json }}
          }{% unless forloop.last %},{% endunless %}
        {%- endfor -%}
      ]
    };
    const cartAddUrl = '{{ routes.cart_add_url | append: ".js" }}';

    const firstVariant = productData.variants[0] || { price: 0 };
    const basePrice = firstVariant.price;

    // Pricing model (per tier):
    //   qty  = total bottles in bundle
    //   free = how many of those bottles are free (BOGO-style)
    //   Customer pays for (qty - free) bottles at basePrice each.
    //   Subscribe layers an extra % discount on top of that total.
    const buildTiers = () => {
      const tiers = [
        {% for i in (1..3) %}
          {% assign qty_key = 'tier_' | append: i | append: '_qty' %}
          {% assign free_key = 'tier_' | append: i | append: '_free' %}
          {% assign save_key = 'tier_' | append: i | append: '_save' %}
          {% assign months_key = 'tier_' | append: i | append: '_months' %}
          {% assign best_key = 'tier_' | append: i | append: '_best' %}
          {% assign sp_key = 'tier_' | append: i | append: '_selling_plan' %}
          {% assign attr_key_key = 'tier_' | append: i | append: '_attr_key' %}
          {% assign attr_val_key = 'tier_' | append: i | append: '_attr_value' %}
          {% if i <= tier_count %}
          {
            qty: {{ block.settings[qty_key] | default: i }},
            free: {{ block.settings[free_key] | default: 0 }},
            subSave: {{ block.settings[save_key] | default: 10 }},
            best: {{ block.settings[best_key] | default: false | json }},
            deliveryMonths: {{ block.settings[months_key] | default: i }},
            sellingPlan: '{{ block.settings[sp_key] | default: "" }}' || null,
            attrKey: {{ block.settings[attr_key_key] | default: "" | json }},
            attrValue: {{ block.settings[attr_val_key] | default: "" | json }}
          },
          {% endif %}
        {% endfor %}
      ];
      return tiers;
    };

    const baseTiers = buildTiers();

    // Single purchase: BOGO math, no extra discount.
    //   price        = what the customer actually pays (paidQty × basePrice)
    //   originalPrice = what qty bottles would cost at full price (qty × basePrice)
    const singleOptions = baseTiers.map(t => {
      const paidQty = Math.max(t.qty - t.free, 0);
      const price = paidQty * basePrice;
      const originalPrice = t.qty * basePrice;
      const hasDiscount = t.free > 0;
      return {
        qty: t.qty,
        free: t.free,
        best: t.best,
        attrKey: t.attrKey,
        attrValue: t.attrValue,
        discount: hasDiscount ? Math.round((t.free / t.qty) * 100) : 0,
        price,
        originalPrice: hasDiscount ? originalPrice : 0
      };
    });

    // Subscribe & Save: same BOGO math, plus extra % off the paid bottles.
    const subOptions = baseTiers.map(t => {
      const paidQty = Math.max(t.qty - t.free, 0);
      const discountMultiplier = 1 - (t.subSave / 100);
      const price = Math.round(paidQty * basePrice * discountMultiplier);
      const originalPrice = t.qty * basePrice;
      return {
        qty: t.qty,
        free: t.free,
        save: t.subSave,
        best: t.best,
        deliveryMonths: t.deliveryMonths,
        sellingPlan: t.sellingPlan,
        attrKey: t.attrKey,
        attrValue: t.attrValue,
        price,
        originalPrice
      };
    });

    const variants = productData.variants.map(v => ({
      id: v.id,
      title: v.title,
      name: v.option1 || v.title,
      available: v.available,
      price: v.price,
      compareAtPrice: v.compare_at_price,
      swatchColor: '#ccc',
      featuredImage: v.featured_image
    }));

    {%- for option in product_resource.options_with_values -%}
      {%- if forloop.first -%}
        {%- for val in option.values -%}
          {%- if val.swatch.color -%}
    if (variants[{{ forloop.index0 }}]) variants[{{ forloop.index0 }}].swatchColor = 'rgb({{ val.swatch.color.rgb }})';
          {%- elsif val.swatch.image -%}
    if (variants[{{ forloop.index0 }}]) variants[{{ forloop.index0 }}].swatchColor = 'url({{ val.swatch.image | image_url: width: 80 }})';
          {%- endif -%}
        {%- endfor -%}
      {%- endif -%}
    {%- endfor -%}

    const defaultShade = Math.min(1, variants.length - 1);
    const unitSingular = {{ unit_singular | json }};
    const unitPlural = {{ unit_plural | json }};
    const freeLabel = {{ free_label | json }};
    const shadeLabel = {{ shade_label | json }};
    const monthSingular = {{ month_singular | json }};
    const monthPlural = {{ month_plural | json }};

    return {
      tab: '{{ block.settings.default_tab | default: "single" }}',
      loading: false,
      variants,
      subOptions,
      singleOptions,
      unitSingular,
      unitPlural,

      formatMoney(cents) {
        return '$' + (cents / 100).toFixed(2).replace(/\.00$/, '');
      },
      singleShades: Array.from({ length: 4 }, () => defaultShade),
      singleQty: 0,
      subQty: 0,
      subShades: Array.from({ length: 4 }, () => defaultShade),

      switchTab(t) { this.tab = t; },
      getVariantName(index) { return this.variants[index]?.name || ''; },
      setSingleShade(index, value) { this.singleShades[index] = value; this.singleShades = [...this.singleShades]; },
      selectSingleQty(i) { this.singleQty = i; },
      selectSubQty(i) { this.subQty = i; },
      setSubShade(index, value) { this.subShades[index] = value; this.subShades = [...this.subShades]; },

      async emitCartUpdated() {
        const cartRes = await fetch('/cart.js');
        const newCart = await cartRes.json();
        document.dispatchEvent(new CustomEvent('cart:updated', { detail: newCart }));
        const drawerDialog = document.querySelector('.cart-drawer__dialog');
        if (drawerDialog) drawerDialog.classList.remove('cart-drawer--empty');
      },

      async openCartDrawer() {
        await this.emitCartUpdated();
        const drawerButton = document.querySelector('.cart-drawer .header-actions__action');
        setTimeout(() => drawerButton?.click(), 500);
      },

      async afterAtc() {
        await this.emitCartUpdated();
        const upsellHandle = {{ bundle_post_atc_upsell.handle | default: "" | json }};
        const popup = document.querySelector('custom-quickview-popup');
        if (!upsellHandle || !popup) {
          this.openCartDrawer();
          return;
        }
        try {
          const url = `${window.Shopify.routes.root}products/${upsellHandle}?section_id=custom-quickview-product`;
          const html = await fetch(url).then(r => r.text());
          const tempDiv = document.createElement('div');
          tempDiv.innerHTML = html;
          const section = tempDiv.querySelector('#shopify-section-custom-quickview-product');
          const content = popup.querySelector('.quickview-sidebar__content');
          if (!section || !content) {
            this.openCartDrawer();
            return;
          }
          content.innerHTML = section.innerHTML;
          const quickviewEl = content.querySelector('custom-quickview-product');
          if (quickviewEl && typeof quickviewEl.connectedCallback === 'function') {
            quickviewEl.connectedCallback();
          }
          popup.querySelector('.quickview-sidebar')?.classList.add('active');
          popup.querySelector('.quickview_overlay')?.classList.add('active');
          document.body.classList.add('scroll_hidden');
        } catch (err) {
          console.error('Upsell sidebar failed:', err);
          this.openCartDrawer();
        }
      },

      // Build a cart-item payload for a given variant id and quantity,
      // attaching the tier's hidden line item attribute + optional selling plan.
      _buildItem(id, quantity, tier, withSellingPlan) {
        const item = { id, quantity };
        if (tier.attrKey) {
          item.properties = { [tier.attrKey]: tier.attrValue || '' };
        }
        if (withSellingPlan && tier.sellingPlan) {
          item.selling_plan = parseInt(tier.sellingPlan);
        }
        return item;
      },

      async addToCartSingle() {
        if (this.loading) return;
        this.loading = true;
        try {
          const useTiers = {{ show_single_tiers | json }};
          const tier = useTiers
            ? this.singleOptions[this.singleQty]
            : { qty: {{ single_units }}, attrKey: '', attrValue: '' };
          const qty = tier.qty;
          const combined = {};
          this.singleShades.slice(0, qty).forEach(idx => {
            const id = this.variants[idx].id;
            combined[id] = (combined[id] || 0) + 1;
          });
          const items = Object.entries(combined).map(([id, quantity]) =>
            this._buildItem(parseInt(id), quantity, tier, false)
          );
          const res = await fetch(cartAddUrl, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ items })
          });
          if (!res.ok) throw new Error('Failed');
          await this.afterAtc();
        } catch (e) { console.error(e); } finally { this.loading = false; }
      },

      async addToCartSubscribe() {
        if (this.loading) return;
        this.loading = true;
        try {
          const tier = this.subOptions[this.subQty];
          const combined = {};
          this.subShades.slice(0, tier.qty).forEach(idx => {
            const id = this.variants[idx].id;
            if (!combined[id]) combined[id] = this._buildItem(id, 0, tier, true);
            combined[id].quantity += 1;
          });
          const res = await fetch(cartAddUrl, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ items: Object.values(combined) })
          });
          if (!res.ok) throw new Error('Failed');
          await this.afterAtc();
        } catch (e) { console.error(e); } finally { this.loading = false; }
      }
    };
  }
</script>

