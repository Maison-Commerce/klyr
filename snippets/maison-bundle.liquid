{%- doc -%}
  Renders the Maison Bundle purchase widget with single purchase / subscribe & save tabs,
  AlpineJS-powered variant swatch selection, selling plan support, and quantity multiplier.

  @param {object} product_resource - The product object.
  @param {object} block - The block object.
  @param {object} section - The section object.
{%- enddoc -%}

{%- liquid
  assign save_percent = block.settings.save_percent | default: 15
  assign low_stock_text = block.settings.low_stock_text | default: 'Low stock: Only few items left'
  assign bogo_text = block.settings.bogo_badge_text | default: 'BOGO SALE'
  assign single_units = block.settings.single_units | default: 2
  assign variant = product_resource.selected_or_first_available_variant
  assign single_price = variant.price | times: single_units | money
  assign single_compare_price = nil
  if variant.compare_at_price and variant.compare_at_price > variant.price
    assign single_compare_price = variant.compare_at_price | times: single_units | money
  endif
  assign trust_1 = block.settings.trust_badge_1 | default: '30-day money back guarantee'
  assign trust_2 = block.settings.trust_badge_2 | default: 'Free shipping from $75'
  assign find_shade_url = block.settings.find_shade_url | default: '#open-quiz-tools/perfect-product-finder/discover-your-perfect-shade'
  assign selling_plan_id = block.settings.selling_plan_id | default: ''

  assign tier_count = block.settings.tier_count | default: 3
-%}

<script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>

<div
  class="maison-bundle"
  x-data="maisonBundle()"
  x-cloak
  data-block-id="{{ block.id }}"
  {{ block.shopify_attributes }}
>
  <!-- Low Stock -->
  {% if block.settings.show_low_stock %}
    <div class="mb-low-stock">
      <span class="mb-low-stock__dot"></span>
      {{ low_stock_text }}
    </div>
  {% endif %}

  <!-- Purchase Type Tabs -->
  <div class="mb-tab-container">
    <div class="mb-tab-slider" :class="{ 'mb-tab-slider--right': tab === 'subscribe' }"></div>
    <button
      class="mb-tab-btn"
      :class="{ 'mb-tab-btn--active': tab === 'single' }"
      @click="switchTab('single')"
      type="button"
    >
      {{ block.settings.single_tab_label | default: 'Single Purchase' }}
    </button>
    <button
      class="mb-tab-btn"
      :class="{ 'mb-tab-btn--active': tab === 'subscribe' }"
      @click="switchTab('subscribe')"
      type="button"
    >
      {{ block.settings.subscribe_tab_label | default: 'Subscribe & Save' }}
      <span class="mb-tab-save-badge">SAVE {{ save_percent }}%</span>
    </button>
  </div>

  <!-- PANELS -->
  <div class="mb-panels-container">

    <!-- SINGLE PURCHASE PANEL -->
    <div class="mb-tab-panel" :class="{ 'mb-tab-panel--hidden': tab !== 'single' }">

      <div class="mb-qty-card mb-qty-card--selected">
        <div class="mb-qty-card__header">
          <span class="mb-qty-card__units">{{ single_units }} Units</span>
          {% if bogo_text != blank %}
            <span class="mb-bogo-badge">{{ bogo_text }}</span>
          {% endif %}
        </div>
        <div class="mb-qty-card__pricing">
          {% if product_resource.compare_at_price > product_resource.price %}
            <span class="mb-price-old">{{ product_resource.compare_at_price | money }}</span>
          {% endif %}
          <span class="mb-price-new">{{ product_resource.price | money }}</span>
        </div>
      </div>

      {% for i in (1..single_units) %}
        <div class="mb-shade-row">
          <div class="mb-shade-label">
            <div>
              <span>{% if single_units > 1 %}Shade {{ i }}:{% else %}Shade:{% endif %}</span>
              <strong x-text="getVariantName(singleShades[{{ i | minus: 1 }}])"></strong>
            </div>
            {% if i == 1 and find_shade_url != blank %}
              <a class="mb-find-shade" href="{{ find_shade_url }}">Find your shade</a>
            {% endif %}
          </div>
          <div class="mb-swatches">
            <template x-for="(variant, idx) in variants" :key="'single-{{ i }}-' + idx">
              <div
                class="mb-swatch"
                :class="{ 'mb-swatch--selected': singleShades[{{ i | minus: 1 }}] === idx }"
                :style="'background:' + variant.swatchColor"
                @click="setSingleShade({{ i | minus: 1 }}, idx)"
              ></div>
            </template>
          </div>
        </div>
      {% endfor %}

      <form action="{{ routes.cart_add_url }}" method="post" @submit.prevent="addToCartSingle()">
        <button type="submit" class="mb-add-to-cart" :disabled="loading">
          <span x-show="!loading">ADD TO CART</span>
          <span x-show="loading">ADDING...</span>
        </button>
      </form>
    </div>

    <!-- SUBSCRIBE & SAVE PANEL -->
    <div class="mb-tab-panel" :class="{ 'mb-tab-panel--hidden': tab !== 'subscribe' }">

      <!-- Subscribe Benefits -->
      <div class="mb-sub-benefits">
        <div class="mb-sub-benefits__grid">
          <div class="mb-sub-benefit">
            <span class="mb-sub-benefit__check">✓</span>
            <span>Save <strong>{{ save_percent }}%</strong> on all deliveries</span>
          </div>
          <div class="mb-sub-benefit">
            <span class="mb-sub-benefit__check">✓</span>
            <span>No commitment - modify or cancel anytime</span>
          </div>
          <div class="mb-sub-benefit">
            <span class="mb-sub-benefit__check">✓</span>
            <span>Free shipping, always</span>
          </div>
          <div class="mb-sub-benefit">
            <span class="mb-sub-benefit__check">✓</span>
            <span>Out of stock protection for consistent result</span>
          </div>
        </div>
      </div>

      <div class="mb-sub-section-label">Choose your quantity</div>
      <div class="mb-qty-selector">
        <template x-for="(opt, i) in subOptions" :key="'sub-qty-' + i">
          <div
            class="mb-qty-option"
            :class="{ 'mb-qty-option--selected': subQty === i }"
            @click="selectSubQty(i)"
          >
            <div class="mb-qty-option__left">
              <span class="mb-qty-option__text" x-text="opt.qty + (opt.qty === 1 ? ' bottle' : ' bottles')"></span>
              <span class="mb-qty-option__save" x-show="opt.save > {{ save_percent }}" x-text="'Save ' + opt.save + '%'"></span>
              <span class="mb-qty-option__best-value" x-show="opt.best">Best Value</span>
            </div>
            <div class="mb-qty-option__right">
              <span class="mb-qty-option__compare" x-text="formatMoney(opt.originalPerBottle)"></span>
              <span class="mb-qty-option__price" x-text="formatMoney(opt.pricePerBottle)"></span>
              <span class="mb-qty-option__per">/bottle</span>
            </div>
          </div>
        </template>
      </div>

      <!-- Delivery Note -->
      <div class="mb-delivery-note">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
        </svg>
        <span>Delivered every <strong x-text="subOptions[subQty].deliveryMonths + (subOptions[subQty].deliveryMonths === 1 ? ' month' : ' months')"></strong></span>
      </div>

      <!-- Shade selectors for subscribe -->
      <template x-for="n in subOptions[subQty].qty" :key="'sub-shade-' + n">
        <div class="mb-shade-row mb-animate-in">
          <div class="mb-shade-label">
            <div>
              <span x-text="subOptions[subQty].qty > 1 ? 'Shade ' + n + ': ' : 'Shade: '"></span>
              <strong x-text="getVariantName(subShades[n - 1] ?? 0)"></strong>
            </div>
            <a class="mb-find-shade" x-show="n === 1" href="{{ find_shade_url }}">Find your shade</a>
          </div>
          <div class="mb-swatches">
            <template x-for="(variant, idx) in variants" :key="'sub-sw-' + n + '-' + idx">
              <div
                class="mb-swatch"
                :class="{ 'mb-swatch--selected': (subShades[n - 1] ?? 0) === idx }"
                :style="'background:' + variant.swatchColor"
                @click="setSubShade(n - 1, idx)"
              ></div>
            </template>
          </div>
        </div>
      </template>

      <form action="{{ routes.cart_add_url }}" method="post" @submit.prevent="addToCartSubscribe()">
        <button type="submit" class="mb-add-to-cart" :disabled="loading">
          <span x-show="!loading">ADD TO CART</span>
          <span x-show="loading">ADDING...</span>
        </button>
      </form>
    </div>

  </div>

  <!-- Trust Badges -->
  {% if trust_1 != blank or trust_2 != blank %}
    <div class="mb-trust-badges">
      {% if trust_1 != blank %}
        <div class="mb-trust-badge">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#555" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M23 4l-6 6-3-3"/>
            <path d="M20 12v6a2 2 0 01-2 2H6a2 2 0 01-2-2V6a2 2 0 012-2h9"/>
          </svg>
          {{ trust_1 }}
        </div>
      {% endif %}
      {% if trust_2 != blank %}
        <div class="mb-trust-badge">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#555" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <rect x="1" y="3" width="15" height="13" rx="2"/>
            <path d="M16 8h4l3 3v5a2 2 0 01-2 2h-1"/>
            <circle cx="5.5" cy="18.5" r="2.5"/>
            <circle cx="18.5" cy="18.5" r="2.5"/>
          </svg>
          {{ trust_2 }}
        </div>
      {% endif %}
    </div>
  {% endif %}
</div>

<script>
  function maisonBundle() {
    const productData = {{ product_resource | json }};
    const sellingPlanId = '{{ selling_plan_id }}' || null;
    const cartAddUrl = '{{ routes.cart_add_url | append: ".js" }}';

    const firstVariant = productData.variants[0];
    const basePrice = firstVariant.price;
    const comparePrice = firstVariant.compare_at_price || basePrice;

    const subOptions = [
      {% for i in (1..3) %}
        {% assign qty_key = 'tier_' | append: i | append: '_qty' %}
        {% assign save_key = 'tier_' | append: i | append: '_save' %}
        {% assign months_key = 'tier_' | append: i | append: '_months' %}
        {% assign best_key = 'tier_' | append: i | append: '_best' %}
        {% if i <= tier_count %}
        {
          qty: {{ block.settings[qty_key] | default: i }},
          save: {{ block.settings[save_key] | default: 15 }},
          best: {{ block.settings[best_key] | default: false | json }},
          deliveryMonths: {{ block.settings[months_key] | default: i }},
          pricePerBottle: Math.round(basePrice * (1 - {{ block.settings[save_key] | default: 15 }} / 100)),
          originalPerBottle: comparePrice
        },
        {% endif %}
      {% endfor %}
    ];

    const variants = productData.variants.map(v => ({
      id: v.id,
      title: v.title,
      name: v.option1 || v.title,
      available: v.available,
      price: v.price,
      compareAtPrice: v.compare_at_price,
      swatchColor: '#ccc',
      featuredImage: v.featured_image
    }));

    {%- for option in product_resource.options_with_values -%}
      {%- if forloop.first -%}
        {%- for val in option.values -%}
          {%- if val.swatch.color -%}
    if (variants[{{ forloop.index0 }}]) variants[{{ forloop.index0 }}].swatchColor = 'rgb({{ val.swatch.color.rgb }})';
          {%- elsif val.swatch.image -%}
    if (variants[{{ forloop.index0 }}]) variants[{{ forloop.index0 }}].swatchColor = 'url({{ val.swatch.image | image_url: width: 80 }})';
          {%- endif -%}
        {%- endfor -%}
      {%- endif -%}
    {%- endfor -%}

    return {
      tab: 'single',
      loading: false,
      variants,
      subOptions,

      formatMoney(cents) {
        return '$' + (cents / 100).toFixed(2).replace(/\.00$/, '');
      },
      singleShades: Array.from({ length: {{ single_units }} }, (_, i) => Math.min(i, variants.length - 1)),
      subQty: 0,
      subShades: [0, 1, 2, 3],

      switchTab(t) { this.tab = t; },
      getVariantName(index) { return this.variants[index]?.name || ''; },
      setSingleShade(index, value) { this.singleShades[index] = value; this.singleShades = [...this.singleShades]; },
      selectSubQty(i) { this.subQty = i; },
      setSubShade(index, value) { this.subShades[index] = value; this.subShades = [...this.subShades]; },

      async openCartDrawer() {
        const cartRes = await fetch('/cart.js');
        const newCart = await cartRes.json();
        document.dispatchEvent(new CustomEvent('cart:updated', { detail: newCart }));
        const drawerDialog = document.querySelector('.cart-drawer__dialog');
        if (drawerDialog) drawerDialog.classList.remove('cart-drawer--empty');
        const drawerButton = document.querySelector('.cart-drawer .header-actions__action');
        setTimeout(() => drawerButton?.click(), 500);
      },

      async addToCartSingle() {
        if (this.loading) return;
        this.loading = true;
        try {
          const combined = {};
          this.singleShades.forEach(idx => {
            const id = this.variants[idx].id;
            combined[id] = (combined[id] || 0) + 1;
          });
          const res = await fetch(cartAddUrl, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ items: Object.entries(combined).map(([id, quantity]) => ({ id: parseInt(id), quantity })) })
          });
          if (!res.ok) throw new Error('Failed');
          await this.openCartDrawer();
        } catch (e) { console.error(e); } finally { this.loading = false; }
      },

      async addToCartSubscribe() {
        if (this.loading) return;
        this.loading = true;
        try {
          const qty = this.subOptions[this.subQty].qty;
          const combined = {};
          this.subShades.slice(0, qty).forEach(idx => {
            const id = this.variants[idx].id;
            if (!combined[id]) combined[id] = { id, quantity: 0 };
            combined[id].quantity += 1;
            if (sellingPlanId) combined[id].selling_plan = parseInt(sellingPlanId);
          });
          const res = await fetch(cartAddUrl, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ items: Object.values(combined) })
          });
          if (!res.ok) throw new Error('Failed');
          await this.openCartDrawer();
        } catch (e) { console.error(e); } finally { this.loading = false; }
      }
    };
  }
</script>

<style>
  [x-cloak] { display: none !important; }

  .maison-bundle {
    width: 100%;
    font-family: var(--swiss721BTLight), sans-serif;
    color: var(--textPrimaryColor, #231c19);
    font-size: 16px;
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
  }

  /* Low Stock */
  .mb-low-stock {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 14px;
    color: var(--textPrimaryColor, #231c19);
    margin-bottom: 24px;
  }
  .mb-low-stock__dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--color-lowstock, #EE9441);
    animation: orangedot 2s linear infinite;
    flex-shrink: 0;
  }
  @keyframes orangedot {
    0% { box-shadow: rgba(238,148,65,.46) 0 0; transform: scale(.95); }
    70% { box-shadow: transparent 0 0 0 10px; transform: scale(1); }
    to { box-shadow: transparent 0 0; transform: scale(.95); }
  }

  /* Tab Switcher */
  .mb-tab-container {
    display: flex;
    border: 1px solid rgba(35, 28, 25, .25);
    overflow: hidden;
    margin-bottom: 24px;
    position: relative;
    background: rgba(35, 28, 25, .04);
  }
  .mb-tab-btn {
    flex: 1;
    padding: 16px 12px;
    font-family: var(--swiss721BTLight), sans-serif;
    font-size: 14px;
    font-weight: 400;
    text-align: center;
    cursor: pointer;
    border: none;
    background: transparent;
    color: rgba(35, 28, 25, .5);
    position: relative;
    z-index: 1;
    transition: color 0.2s ease;
    line-height: 1.3;
  }
  .mb-tab-btn--active {
    color: var(--textPrimaryColor, #231c19);
    font-family: var(--swiss721BTMedium), sans-serif;
    font-weight: 500;
  }
  .mb-tab-slider {
    position: absolute;
    top: 0; left: 0;
    width: 50%;
    height: 100%;
    background: #fff;
    border: 1px solid rgba(35, 28, 25, .25);
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    z-index: 0;
  }
  .mb-tab-slider--right { transform: translateX(100%); }
  .mb-tab-save-badge {
    display: inline-block;
    background: var(--darkRedColor, rgb(163, 42, 60));
    color: #fff;
    font-family: var(--swiss721BTMedium), sans-serif;
    font-size: 10px;
    font-weight: 500;
    padding: 3px 6px;
    margin-left: 4px;
    letter-spacing: 0.3px;
    vertical-align: middle;
    position: relative;
    top: -1px;
  }

  /* Panels */
  .mb-panels-container { position: relative; }
  .mb-tab-panel {
    transition: opacity 0.3s ease, visibility 0.3s ease, transform 0.3s ease;
    opacity: 1; visibility: visible; transform: translateY(0);
  }
  .mb-tab-panel--hidden {
    position: absolute; top: 0; left: 0; right: 0;
    opacity: 0; visibility: hidden; transform: translateY(6px); pointer-events: none;
  }

  /* Subscribe Benefits Grid */
  .mb-sub-benefits {
    background: var(--textPrimaryColor, #231c19);
    padding: 24px;
    margin-bottom: 24px;
  }
  .mb-sub-benefits__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }
  .mb-sub-benefit {
    display: flex;
    align-items: flex-start;
    gap: 8px;
    font-size: 14px;
    color: #fff;
    font-family: var(--swiss721BTLight), sans-serif;
    line-height: 1.4;
  }
  .mb-sub-benefit__check {
    color: #c9a96e;
    font-size: 16px;
    flex-shrink: 0;
    line-height: 1.3;
  }
  .mb-sub-benefit strong {
    font-family: var(--swiss721BTMedium), sans-serif;
    font-weight: 500;
  }

  /* Single Purchase Card */
  .mb-qty-card {
    border: 1px solid rgba(35, 28, 25, .25);
    padding: 16px 18px;
    margin-bottom: 24px;
    transition: border-color 0.2s ease;
  }
  .mb-qty-card--selected { border-color: var(--textPrimaryColor, #231c19); }
  .mb-qty-card__header { display: flex; align-items: center; gap: 10px; margin-bottom: 4px; }
  .mb-qty-card__units {
    font-size: 16px;
    font-family: var(--swiss721BTMedium), sans-serif;
    font-weight: 500;
  }
  .mb-bogo-badge {
    background: var(--darkRedColor, rgb(163, 42, 60));
    color: #fff;
    font-size: 12px;
    font-family: var(--swiss721BTMedium), sans-serif;
    font-weight: 500;
    padding: 4px 8px;
    line-height: 9px;
  }
  .mb-qty-card__pricing { display: flex; align-items: center; gap: 8px; }
  .mb-price-old {
    font-size: 16px;
    color: var(--textPrimaryColor, #231c19);
    opacity: .5;
    text-decoration: line-through;
    font-family: var(--swiss721BTMedium), sans-serif;
  }
  .mb-price-new {
    font-size: 16px;
    font-family: var(--swiss721BTMedium), sans-serif;
    font-weight: 500;
    color: var(--redColor, rgb(163, 42, 60));
  }

  /* Subscribe Section */
  .mb-sub-section-label {
    font-size: 14px;
    color: var(--textPrimaryColor, #231c19);
    opacity: .5;
    font-family: var(--swiss721BTLight), sans-serif;
    margin-bottom: 10px;
  }
  .mb-qty-selector { display: flex; flex-direction: column; gap: 8px; margin-bottom: 20px; }
  .mb-qty-option {
    display: flex; align-items: center; justify-content: space-between;
    border: 1px solid rgba(35, 28, 25, .25);
    padding: 11px 14px;
    cursor: pointer; transition: all 0.2s ease; background: #fff;
    min-height: 42px;
  }
  .mb-qty-option:hover { border-color: rgba(35, 28, 25, .5); }
  .mb-qty-option--selected { border-color: var(--textPrimaryColor, #231c19); }
  .mb-qty-option__left { display: flex; align-items: center; gap: 8px; }
  .mb-qty-option__text {
    font-size: 16px;
    font-family: var(--swiss721BTLight), sans-serif;
    color: var(--textPrimaryColor, #231c19);
    line-height: 17px;
  }
  .mb-qty-option__save {
    font-size: 12px;
    font-family: var(--swiss721BTMedium), sans-serif;
    color: var(--darkRedColor, rgb(163, 42, 60));
    background: rgba(163, 42, 60, .08);
    padding: 4px 6px;
    line-height: 9px;
  }
  .mb-qty-option__best-value {
    font-size: 12px;
    font-family: var(--swiss721BTMedium), sans-serif;
    color: #fff;
    background: var(--textPrimaryColor, #231c19);
    padding: 4px 6px;
    line-height: 9px;
    letter-spacing: 0.3px;
    text-transform: uppercase;
  }
  .mb-qty-option__right { display: flex; align-items: center; gap: 6px; }
  .mb-qty-option__compare {
    font-size: 14px;
    color: var(--textPrimaryColor, #231c19);
    opacity: .5;
    text-decoration: line-through;
    font-family: var(--swiss721BTMedium), sans-serif;
  }
  .mb-qty-option__price {
    font-size: 16px;
    font-family: var(--swiss721BTMedium), sans-serif;
    color: var(--textPrimaryColor, #231c19);
  }
  .mb-qty-option__per {
    font-size: 14px;
    color: var(--textPrimaryColor, #231c19);
    opacity: .5;
    font-family: var(--swiss721BTLight), sans-serif;
  }

  /* Delivery Note */
  .mb-delivery-note {
    font-size: 14px;
    color: var(--textPrimaryColor, #231c19);
    opacity: .6;
    margin-bottom: 24px;
    display: flex; align-items: center; gap: 6px;
    font-family: var(--swiss721BTLight), sans-serif;
  }
  .mb-delivery-note svg { flex-shrink: 0; }
  .mb-delivery-note strong {
    font-family: var(--swiss721BTMedium), sans-serif;
    font-weight: 500;
  }

  /* Shade Selection */
  .mb-shade-row { margin-bottom: 24px; }
  .mb-shade-label {
    font-size: 16px;
    color: var(--textPrimaryColor, #231c19);
    margin-bottom: 12px;
    display: flex; justify-content: space-between; align-items: center;
    font-family: var(--swiss721BTLight), sans-serif;
    line-height: 100%;
  }
  .mb-shade-label span { font-weight: 400; }
  .mb-shade-label strong {
    font-family: var(--swiss721BTMedium), sans-serif;
    font-weight: 500;
