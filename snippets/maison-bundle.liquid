{%- doc -%}
  Renders the Maison Bundle purchase widget with single purchase / subscribe & save tabs,
  AlpineJS-powered variant swatch selection, selling plan support, and quantity multiplier.

  @param {object} product_resource - The product object.
  @param {object} block - The block object.
  @param {object} section - The section object.
{%- enddoc -%}

{%- liquid
  assign save_percent = block.settings.save_percent | default: 15
  assign low_stock_text = block.settings.low_stock_text | default: 'Low stock: Only few items left'
  assign bogo_text = block.settings.bogo_badge_text | default: 'BOGO SALE'
  assign single_units = block.settings.single_units | default: 2
  assign single_compare_price = block.settings.single_compare_price
  assign single_price = block.settings.single_price
  assign cancel_note = block.settings.cancel_note | default: 'Cancel or modify anytime — no commitments'
  assign trust_1 = block.settings.trust_badge_1 | default: '30-day money back guarantee'
  assign trust_2 = block.settings.trust_badge_2 | default: 'Free shipping from $75'
  assign find_shade_url = block.settings.find_shade_url | default: '#open-quiz-tools/perfect-product-finder/discover-your-perfect-shade'
  assign selling_plan_id = block.settings.selling_plan_id | default: ''

  assign sub_options_json = '[]'
  assign sub_count = 0
  assign sub_items = ''

  for b in section.blocks
    if b.type == 'maison-bundle-sub-option'
      assign sub_count = sub_count | plus: 1
      assign item = '{"qty":' | append: b.settings.quantity | append: ',"pricePerBottle":' | append: b.settings.price_per_bottle | append: ',"originalPerBottle":' | append: b.settings.compare_price_per_bottle | append: ',"save":' | append: b.settings.save_percent | append: ',"best":' | append: b.settings.best_value | append: ',"deliveryMonths":' | append: b.settings.delivery_months | append: '}'
      if sub_items != ''
        assign sub_items = sub_items | append: ',' | append: item
      else
        assign sub_items = item
      endif
    endif
  endfor

  if sub_count > 0
    assign sub_options_json = '[' | append: sub_items | append: ']'
  endif
-%}

<script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>

<div
  class="maison-bundle"
  x-data="maisonBundle()"
  x-cloak
  data-block-id="{{ block.id }}"
  {{ block.shopify_attributes }}
>
  <!-- Low Stock -->
  {% if block.settings.show_low_stock %}
    <div class="mb-low-stock">
      <span class="mb-low-stock__dot"></span>
      {{ low_stock_text }}
    </div>
  {% endif %}

  <!-- Purchase Type Tabs -->
  <div class="mb-tab-container">
    <div class="mb-tab-slider" :class="{ 'mb-tab-slider--right': tab === 'subscribe' }"></div>
    <button
      class="mb-tab-btn"
      :class="{ 'mb-tab-btn--active': tab === 'single' }"
      @click="switchTab('single')"
      type="button"
    >
      {{ block.settings.single_tab_label | default: 'Single Purchase' }}
    </button>
    <button
      class="mb-tab-btn"
      :class="{ 'mb-tab-btn--active': tab === 'subscribe' }"
      @click="switchTab('subscribe')"
      type="button"
    >
      {{ block.settings.subscribe_tab_label | default: 'Subscribe & Save' }}
      <span class="mb-tab-save-badge">SAVE {{ save_percent }}%</span>
    </button>
  </div>

  <!-- PANELS -->
  <div class="mb-panels-container">

    <!-- SINGLE PURCHASE PANEL -->
    <div class="mb-tab-panel" :class="{ 'mb-tab-panel--hidden': tab !== 'single' }">

      <div class="mb-qty-card mb-qty-card--selected">
        <div class="mb-qty-card__header">
          <span class="mb-qty-card__units">{{ single_units }} Units</span>
          {% if bogo_text != blank %}
            <span class="mb-bogo-badge">{{ bogo_text }}</span>
          {% endif %}
        </div>
        <div class="mb-qty-card__pricing">
          {% if single_compare_price != blank %}
            <span class="mb-price-old">${{ single_compare_price }}</span>
          {% endif %}
          {% if single_price != blank %}
            <span class="mb-price-new">${{ single_price }}</span>
          {% endif %}
        </div>
      </div>

      {% for i in (1..single_units) %}
        <div class="mb-shade-row">
          <div class="mb-shade-label">
            <div>
              <span>{% if single_units > 1 %}Shade {{ i }}:{% else %}Shade:{% endif %}</span>
              <strong x-text="getVariantName(singleShades[{{ i | minus: 1 }}])"></strong>
            </div>
            {% if i == 1 and find_shade_url != blank %}
              <a class="mb-find-shade" href="{{ find_shade_url }}">Find your shade</a>
            {% endif %}
          </div>
          <div class="mb-swatches">
            <template x-for="(variant, idx) in variants" :key="'single-{{ i }}-' + idx">
              <div
                class="mb-swatch"
                :class="{ 'mb-swatch--selected': singleShades[{{ i | minus: 1 }}] === idx }"
                :style="'background:' + variant.swatchColor"
                @click="setSingleShade({{ i | minus: 1 }}, idx)"
              ></div>
            </template>
          </div>
        </div>
      {% endfor %}

      <form action="{{ routes.cart_add_url }}" method="post" @submit.prevent="addToCartSingle()">
        <button type="submit" class="mb-add-to-cart" :disabled="loading">
          <span x-show="!loading">ADD TO CART</span>
          <span x-show="loading">ADDING...</span>
        </button>
      </form>
    </div>

    <!-- SUBSCRIBE & SAVE PANEL -->
    <div class="mb-tab-panel" :class="{ 'mb-tab-panel--hidden': tab !== 'subscribe' }">

      <div class="mb-sub-section-label">Choose your quantity</div>
      <div class="mb-qty-selector">
        {% assign sub_index = 0 %}
        {% for b in section.blocks %}
          {% if b.type == 'maison-bundle-sub-option' %}
            <div
              class="mb-qty-option"
              :class="{ 'mb-qty-option--selected': subQty === {{ sub_index }} }"
              @click="selectSubQty({{ sub_index }})"
            >
              <div class="mb-qty-option__left">
                <span class="mb-qty-option__text">
                  {{ b.settings.quantity }} {% if b.settings.quantity == 1 %}bottle{% else %}bottles{% endif %}
                </span>
                {% if b.settings.save_percent > save_percent %}
                  <span class="mb-qty-option__save">Save {{ b.settings.save_percent }}%</span>
                {% endif %}
                {% if b.settings.best_value %}
                  <span class="mb-qty-option__best-value">Best Value</span>
                {% endif %}
              </div>
              <div class="mb-qty-option__right">
                {% if b.settings.compare_price_per_bottle != blank %}
                  <span class="mb-qty-option__compare">${{ b.settings.compare_price_per_bottle }}</span>
                {% endif %}
                <span class="mb-qty-option__price">${{ b.settings.price_per_bottle }}</span>
                <span class="mb-qty-option__per">/bottle</span>
              </div>
            </div>
            {% assign sub_index = sub_index | plus: 1 %}
          {% endif %}
        {% endfor %}
      </div>

      <!-- Delivery Note -->
      <div class="mb-delivery-note">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
        </svg>
        <span>Delivered every <strong x-text="subOptions[subQty].deliveryMonths + (subOptions[subQty].deliveryMonths === 1 ? ' month' : ' months')"></strong></span>
      </div>

      <!-- Shade selectors for subscribe -->
      <template x-for="n in subOptions[subQty].qty" :key="'sub-shade-' + n">
        <div class="mb-shade-row mb-animate-in">
          <div class="mb-shade-label">
            <div>
              <span x-text="subOptions[subQty].qty > 1 ? 'Shade ' + n + ': ' : 'Shade: '"></span>
              <strong x-text="getVariantName(subShades[n - 1] ?? 0)"></strong>
            </div>
            <a class="mb-find-shade" x-show="n === 1" href="{{ find_shade_url }}">Find your shade</a>
          </div>
          <div class="mb-swatches">
            <template x-for="(variant, idx) in variants" :key="'sub-sw-' + n + '-' + idx">
              <div
                class="mb-swatch"
                :class="{ 'mb-swatch--selected': (subShades[n - 1] ?? 0) === idx }"
                :style="'background:' + variant.swatchColor"
                @click="setSubShade(n - 1, idx)"
              ></div>
            </template>
          </div>
        </div>
      </template>

      <p class="mb-cancel-note">{{ cancel_note }}</p>

      <form action="{{ routes.cart_add_url }}" method="post" @submit.prevent="addToCartSubscribe()">
        <button type="submit" class="mb-add-to-cart" :disabled="loading">
          <span x-show="!loading">ADD TO CART</span>
          <span x-show="loading">ADDING...</span>
        </button>
      </form>
    </div>

  </div>

  <!-- Trust Badges -->
  {% if trust_1 != blank or trust_2 != blank %}
    <div class="mb-trust-badges">
      {% if trust_1 != blank %}
        <div class="mb-trust-badge">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#555" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M23 4l-6 6-3-3"/>
            <path d="M20 12v6a2 2 0 01-2 2H6a2 2 0 01-2-2V6a2 2 0 012-2h9"/>
          </svg>
          {{ trust_1 }}
        </div>
      {% endif %}
      {% if trust_2 != blank %}
        <div class="mb-trust-badge">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#555" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <rect x="1" y="3" width="15" height="13" rx="2"/>
            <path d="M16 8h4l3 3v5a2 2 0 01-2 2h-1"/>
            <circle cx="5.5" cy="18.5" r="2.5"/>
            <circle cx="18.5" cy="18.5" r="2.5"/>
          </svg>
          {{ trust_2 }}
        </div>
      {% endif %}
    </div>
  {% endif %}
</div>

<script>
  function maisonBundle() {
    const productData = {{ product_resource | json }};
    const sellingPlanId = '{{ selling_plan_id }}' || null;
    const cartAddUrl = '{{ routes.cart_add_url | append: ".js" }}';
    const subOptions = {{ sub_options_json }};

    const variants = productData.variants.map(v => ({
      id: v.id,
      title: v.title,
      name: v.option1 || v.title,
      available: v.available,
      price: v.price,
      compareAtPrice: v.compare_at_price,
      swatchColor: '#ccc',
      featuredImage: v.featured_image
    }));

    {%- for option in product_resource.options_with_values -%}
      {%- if forloop.first -%}
        {%- for val in option.values -%}
          {%- if val.swatch.color -%}
    if (variants[{{ forloop.index0 }}]) variants[{{ forloop.index0 }}].swatchColor = 'rgb({{ val.swatch.color.rgb }})';
          {%- elsif val.swatch.image -%}
    if (variants[{{ forloop.index0 }}]) variants[{{ forloop.index0 }}].swatchColor = 'url({{ val.swatch.image | image_url: width: 80 }})';
          {%- endif -%}
        {%- endfor -%}
      {%- endif -%}
    {%- endfor -%}

    return {
      tab: 'single',
      loading: false,
      variants,
      subOptions: subOptions.length ? subOptions : [{ qty: 1, pricePerBottle: 50, originalPerBottle: 59, save: 15, best: false, deliveryMonths: 1 }],
      singleShades: Array.from({ length: {{ single_units }} }, (_, i) => Math.min(i, variants.length - 1)),
      subQty: 0,
      subShades: [0, 1, 2, 3],

      switchTab(t) { this.tab = t; },
      getVariantName(index) { return this.variants[index]?.name || ''; },
      setSingleShade(index, value) { this.singleShades[index] = value; this.singleShades = [...this.singleShades]; },
      selectSubQty(i) { this.subQty = i; },
      setSubShade(index, value) { this.subShades[index] = value; this.subShades = [...this.subShades]; },

      async addToCartSingle() {
        if (this.loading) return;
        this.loading = true;
        try {
          const combined = {};
          this.singleShades.forEach(idx => {
            const id = this.variants[idx].id;
            combined[id] = (combined[id] || 0) + 1;
          });
          const res = await fetch(cartAddUrl, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ items: Object.entries(combined).map(([id, quantity]) => ({ id: parseInt(id), quantity })) })
          });
          if (!res.ok) throw new Error('Failed');
          document.dispatchEvent(new CustomEvent('cart:updated'));
          window.location.href = '{{ routes.cart_url }}';
        } catch (e) { console.error(e); } finally { this.loading = false; }
      },

      async addToCartSubscribe() {
        if (this.loading) return;
        this.loading = true;
        try {
          const qty = this.subOptions[this.subQty].qty;
          const combined = {};
          this.subShades.slice(0, qty).forEach(idx => {
            const id = this.variants[idx].id;
            if (!combined[id]) combined[id] = { id, quantity: 0 };
            combined[id].quantity += 1;
            if (sellingPlanId) combined[id].selling_plan = parseInt(sellingPlanId);
          });
          const res = await fetch(cartAddUrl, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ items: Object.values(combined) })
          });
          if (!res.ok) throw new Error('Failed');
          document.dispatchEvent(new CustomEvent('cart:updated'));
          window.location.href = '{{ routes.cart_url }}';
        } catch (e) { console.error(e); } finally { this.loading = false; }
      }
    };
  }
</script>

<style>
  [x-cloak] { display: none !important; }

  .maison-bundle {
    width: 100%;
    font-family: var(--font-paragraph--family), sans-serif;
    color: #1a1a1a;
    -webkit-font-smoothing: antialiased;
  }

  .mb-low-stock {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 14px;
    color: #555;
    margin-bottom: 24px;
  }
  .mb-low-stock__dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: #e8a030;
    flex-shrink: 0;
  }

  .mb-tab-container {
    display: flex;
    border: 1.5px solid #e0e0e0;
    border-radius: 10px;
    overflow: hidden;
    margin-bottom: 28px;
    position: relative;
    background: #fafafa;
  }
  .mb-tab-btn {
    flex: 1;
    padding: 16px 12px;
    font-family: var(--font-paragraph--family), sans-serif;
    font-size: 14px;
    font-weight: 500;
    text-align: center;
    cursor: pointer;
    border: none;
    background: transparent;
    color: #777;
    position: relative;
    z-index: 1;
    transition: color 0.3s ease;
    line-height: 1.3;
  }
  .mb-tab-btn--active { color: #1a1a1a; font-weight: 600; }
  .mb-tab-slider {
    position: absolute;
    top: 3px;
    left: 3px;
    width: calc(50% - 3px);
    height: calc(100% - 6px);
    background: #fff;
    border-radius: 8px;
    box-shadow: 0 1px 4px rgba(0,0,0,0.1);
    transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    z-index: 0;
  }
  .mb-tab-slider--right { transform: translateX(100%); }
  .mb-tab-save-badge {
    display: inline-block;
    background: #b8232a;
    color: #fff;
    font-size: 10px;
    font-weight: 700;
    padding: 2px 6px;
    border-radius: 3px;
    margin-left: 4px;
    letter-spacing: 0.3px;
    vertical-align: middle;
    position: relative;
    top: -1px;
  }

  .mb-panels-container { position: relative; }
  .mb-tab-panel {
    transition: opacity 0.3s ease, visibility 0.3s ease, transform 0.3s ease;
    opacity: 1; visibility: visible; transform: translateY(0);
  }
  .mb-tab-panel--hidden {
    position: absolute; top: 0; left: 0; right: 0;
    opacity: 0; visibility: hidden; transform: translateY(6px); pointer-events: none;
  }

  .mb-qty-card {
    border: 1.5px solid #e0e0e0;
    border-radius: 10px;
    padding: 16px 18px;
    margin-bottom: 28px;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }
  .mb-qty-card--selected { border-color: #1a1a1a; box-shadow: 0 0 0 1px #1a1a1a; }
  .mb-qty-card__header { display: flex; align-items: center; gap: 10px; margin-bottom: 4px; }
  .mb-qty-card__units { font-size: 16px; font-weight: 500; }
  .mb-bogo-badge {
    background: #b8232a; color: #fff; font-size: 11px; font-weight: 700;
    padding: 2px 8px; border-radius: 3px; letter-spacing: 0.3px;
  }
  .mb-qty-card__pricing { display: flex; align-items: center; gap: 8px; }
  .mb-price-old { font-size: 15px; color: #999; text-decoration: line-through; }
  .mb-price-new { font-size: 17px; font-weight: 700; color: #b8232a; }

  .mb-sub-section-label { font-size: 13px; color: #777; font-weight: 500; margin-bottom: 10px; letter-spacing: 0.2px; }
  .mb-qty-selector { display: flex; flex-direction: column; gap: 8px; margin-bottom: 20px; }
  .mb-qty-option {
    display: flex; align-items: center; justify-content: space-between;
    border: 1.5px solid #e0e0e0; border-radius: 8px; padding: 12px 14px;
    cursor: pointer; transition: all 0.25s ease; background: #fff;
  }
  .mb-qty-option:hover { border-color: #bbb; }
  .mb-qty-option--selected { border-color: #1a1a1a; box-shadow: 0 0 0 1px #1a1a1a; }
  .mb-qty-option__left { display: flex; align-items: center; gap: 8px; }
  .mb-qty-option__text { font-size: 14px; font-weight: 600; color: #1a1a1a; }
  .mb-qty-option__save { font-size: 10px; font-weight: 700; color: #b8232a; background: #fef2f2; padding: 2px 6px; border-radius: 3px; }
  .mb-qty-option__best-value { font-size: 9px; font-weight: 700; color: #fff; background: #1a1a1a; padding: 2px 6px; border-radius: 3px; letter-spacing: 0.3px; text-transform: uppercase; }
  .mb-qty-option__right { display: flex; align-items: center; gap: 6px; }
  .mb-qty-option__compare { font-size: 12px; color: #999; text-decoration: line-through; font-weight: 500; }
  .mb-qty-option__price { font-size: 14px; font-weight: 700; color: #1a1a1a; }
  .mb-qty-option__per { font-size: 11px; color: #888; font-weight: 500; }

  .mb-delivery-note { font-size: 13px; color: #777; margin-bottom: 28px; display: flex; align-items: center; gap: 6px; }
  .mb-delivery-note svg { flex-shrink: 0; }
  .mb-delivery-note strong { font-weight: 600; color: #555; }

  .mb-shade-row { margin-bottom: 24px; }
  .mb-shade-label { font-size: 14px; color: #1a1a1a; margin-bottom: 10px; display: flex; justify-content: space-between; align-items: center; }
  .mb-shade-label span { font-weight: 400; }
  .mb-shade-label strong { font-weight: 700; }
  .mb-find-shade { font-size: 14px; color: #1a1a1a; text-decoration: underline; text-underline-offset: 3px; cursor: pointer; font-weight: 500; }
  .mb-swatches { display: flex; gap: 10px; flex-wrap: wrap; }
  .mb-swatch {
    width: 44px; height: 44px; border-radius: 6px; cursor: pointer;
    border: 2px solid transparent; transition: border-color 0.2s ease, transform 0.15s ease;
    background-size: cover; background-position: center;
  }
  .mb-swatch:hover { transform: scale(1.08); }
  .mb-swatch--selected { border-color: #1a1a1a; }

  .mb-add-to-cart {
    width: 100%; background: #1a1a1a; color: #fff; border: none; border-radius: 10px;
    padding: 20px; font-family: var(--font-paragraph--family), sans-serif;
    font-size: 15px; font-weight: 600; letter-spacing: 1.5px; text-transform: uppercase;
    cursor: pointer; transition: background 0.2s ease, transform 0.15s ease; margin-bottom: 20px;
  }
  .mb-add-to-cart:hover { background: #333; }
  .mb-add-to-cart:active { transform: scale(0.985); }
  .mb-add-to-cart:disabled { opacity: 0.7; cursor: not-allowed; }

  .mb-trust-badges { display: flex; flex-direction: column; align-items: center; gap: 10px; margin-bottom: 32px; }
  .mb-trust-badge { display: flex; align-items: center; gap: 8px; font-size: 14px; color: #555; }
  .mb-trust-badge svg { flex-shrink: 0; }

  .mb-cancel-note { text-align: center; font-size: 12px; color: #999; margin-bottom: 24px; }

  @keyframes mb-fadeSlideIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
  .mb-animate-in { animation: mb-fadeSlideIn 0.35s ease forwards; }
</style>
