    "new_product_faq_nq96kP": {
      "type": "new-product-faq",
      "blocks": {
        "faq_pCwbXq": {
          "type": "faq",
          "settings": {
            "question": "Is it necessary to use a sponge?",
            "answer": "<p>No, you can also use your fingertips. For the most even and natural finish, we recommend blending with the Klyr Concealing Sponge+.</p>"
          }
        },
        "faq_Ajc4zT": {
          "type": "faq",
          "settings": {
            "question": "How much coverage does it provide?",
            "answer": "<p>Concealing Cream+ offers light to medium coverage. It hides dark circles, redness, and blemishes while keeping your skin looking natural.</p>"
          }
        },
        "faq_NyyNig": {
          "type": "faq",
          "settings": {
            "question": "Is the product suitable for sensitive skin?",
            "answer": "<p>Yes. Concealing Cream+ is made with skin-friendly ingredients, non-comedogenic, and free from harsh chemicals, making it safe for daily use even on the sensitive skin.</p>"
          }
        },
        "faq_rUkDHX": {
          "type": "faq",
          "settings": {
            "question": "What if I choose the wrong shade?",
            "answer": "<p>Our Shade Technology helps Concealing Cream+ adapt naturally to your skin tone, and you can use the shade quiz to find your best match before ordering. Still not right? You’re covered by our 100% Shade Match Guarantee we’ll send you a new shade or give you a full refund, no questions asked.</p>"
          }
        },
        "faq_dpRRnp": {
          "type": "faq",
          "settings": {
            "question": "How long does it last?",
            "answer": "<p>The formula is lightweight but long-lasting, staying in place for hours during work, social events, or nights out.</p>"
          }
        },
        "faq_G3idpd": {
          "type": "faq",
          "settings": {
            "question": "Is it waterproof?",
            "answer": "<p>Concealing Cream+ is water-resistant, meaning it holds up against sweat, light rain, and daily activity. For full waterproof protection (like swimming), re-application may be needed.</p>"
          }
        }
      },
