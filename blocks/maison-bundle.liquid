{% liquid
  assign product_resource = closest.product
  if request.visual_preview_mode and product_resource == blank
    assign product_resource = collections.all.products.first
  endif
%}

{% render 'maison-bundle', product_resource: product_resource, block: block, section: section %}

{% schema %}
{
  "name": "Maison Bundle",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Low Stock"
    },
    {
      "type": "checkbox",
      "id": "show_low_stock",
      "label": "Show low stock indicator",
      "default": true
    },
    {
      "type": "text",
      "id": "low_stock_text",
      "label": "Low stock text",
      "default": "Low stock: Only few items left"
    },
    {
      "type": "header",
      "content": "Tabs"
    },
    {
      "type": "text",
      "id": "single_tab_label",
      "label": "Single purchase tab label",
      "default": "Single Purchase"
    },
    {
      "type": "text",
      "id": "subscribe_tab_label",
      "label": "Subscribe tab label",
      "default": "Subscribe & Save"
    },
    {
      "type": "number",
      "id": "save_percent",
      "label": "Save percentage badge",
      "default": 15
    },
    {
      "type": "header",
      "content": "Single Purchase"
    },
    {
      "type": "number",
      "id": "single_units",
      "label": "Number of units (quantity multiplier)",
      "default": 2
    },
    {
      "type": "text",
      "id": "bogo_badge_text",
      "label": "Badge text",
      "default": "BOGO SALE"
    },
    {
      "type": "header",
      "content": "Subscribe & Save"
    },
    {
      "type": "text",
      "id": "selling_plan_id",
      "label": "Selling Plan ID",
      "info": "Enter the numeric selling plan ID to attach when subscribe & save is selected"
    },
    {
      "type": "range",
      "id": "tier_count",
      "label": "Number of tiers",
      "min": 1,
      "max": 3,
      "step": 1,
      "default": 3
    },
    {
      "type": "header",
      "content": "Tier 1"
    },
    {
      "type": "number",
      "id": "tier_1_qty",
      "label": "Tier 1 — Bottles",
      "default": 1
    },
    {
      "type": "number",
      "id": "tier_1_save",
      "label": "Tier 1 — Save %",
      "default": 15
    },
    {
      "type": "number",
      "id": "tier_1_months",
      "label": "Tier 1 — Delivery every X months",
      "default": 1
    },
    {
      "type": "checkbox",
      "id": "tier_1_best",
      "label": "Tier 1 — Best Value badge",
      "default": false
    },
    {
      "type": "header",
      "content": "Tier 2"
    },
    {
      "type": "number",
      "id": "tier_2_qty",
      "label": "Tier 2 — Bottles",
      "default": 2
    },
    {
      "type": "number",
      "id": "tier_2_save",
      "label": "Tier 2 — Save %",
      "default": 24
    },
    {
      "type": "number",
      "id": "tier_2_months",
      "label": "Tier 2 — Delivery every X months",
      "default": 2
    },
    {
      "type": "checkbox",
      "id": "tier_2_best",
      "label": "Tier 2 — Best Value badge",
      "default": false
    },
    {
      "type": "header",
      "content": "Tier 3"
    },
    {
      "type": "number",
      "id": "tier_3_qty",
      "label": "Tier 3 — Bottles",
      "default": 4
    },
    {
      "type": "number",
      "id": "tier_3_save",
      "label": "Tier 3 — Save %",
      "default": 32
    },
    {
      "type": "number",
      "id": "tier_3_months",
      "label": "Tier 3 — Delivery every X months",
      "default": 4
    },
    {
      "type": "checkbox",
      "id": "tier_3_best",
      "label": "Tier 3 — Best Value badge",
      "default": true
    },
    {
      "type": "header",
      "content": "Shade Finder"
    },
    {
      "type": "url",
      "id": "find_shade_url",
      "label": "Find your shade link"
    },
    {
      "type": "header",
      "content": "Trust Badges"
    },
    {
      "type": "text",
      "id": "trust_badge_1",
      "label": "Trust badge 1",
      "default": "30-day money back guarantee"
    },
    {
      "type": "text",
      "id": "trust_badge_2",
      "label": "Trust badge 2",
      "default": "Free shipping from $75"
    },
    {
      "type": "text",
      "id": "cancel_note",
      "label": "Cancel note text",
      "default": "Cancel or modify anytime — no commitments"
    }
  ],
  "presets": [
    {
      "name": "Maison Bundle"
    }
  ]
}
{% endschema %}
