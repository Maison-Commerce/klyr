{% liquid
  assign product_resource = closest.product
  if request.visual_preview_mode and product_resource == blank
    assign product_resource = collections.all.products.first
  endif
%}

{% render 'maison-bundle', product_resource: product_resource, block: block, section: section %}

{% schema %}
{
  "name": "Maison Bundle",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Low Stock"
    },
    {
      "type": "checkbox",
      "id": "show_low_stock",
      "label": "Show low stock indicator",
      "default": true
    },
    {
      "type": "text",
      "id": "low_stock_text",
      "label": "Low stock text",
      "default": "Low stock: Only few items left"
    },
    {
      "type": "header",
      "content": "Tabs"
    },
    {
      "type": "text",
      "id": "single_tab_label",
      "label": "Single purchase tab label",
      "default": "Single Purchase"
    },
    {
      "type": "text",
      "id": "subscribe_tab_label",
      "label": "Subscribe tab label",
      "default": "Subscribe & Save"
    },
    {
      "type": "number",
      "id": "save_percent",
      "label": "Save percentage badge",
      "default": 15
    },
    {
      "type": "header",
      "content": "Single Purchase"
    },
    {
      "type": "checkbox",
      "id": "show_single_tiers",
      "label": "Show quantity tiers (instead of BOGO card)",
      "default": false
    },
    {
      "type": "number",
      "id": "single_units",
      "label": "Number of units (quantity multiplier) — used when tiers are off",
      "default": 2
    },
    {
      "type": "text",
      "id": "bogo_badge_text",
      "label": "Badge text — used when tiers are off",
      "default": "BOGO SALE"
    },
    {
      "type": "header",
      "content": "Subscribe & Save"
    },
    {
      "type": "select",
      "id": "default_tab",
      "label": "Default active tab",
      "options": [
        { "value": "single", "label": "Single Purchase" },
        { "value": "subscribe", "label": "Subscribe & Save" }
      ],
      "default": "single"
    },
    {
      "type": "range",
      "id": "tier_count",
      "label": "Number of tiers",
      "min": 1,
      "max": 3,
      "step": 1,
      "default": 3
    },
    {
      "type": "header",
      "content": "Tier 1"
    },
    {
      "type": "number",
      "id": "tier_1_qty",
      "label": "Tier 1 — Bottles",
      "default": 1
    },
    {
      "type": "number",
      "id": "tier_1_free",
      "label": "Tier 1 — Free bottles (from qty)",
      "default": 0
    },
    {
      "type": "number",
      "id": "tier_1_save",
      "label": "Tier 1 — Subscribe extra discount %",
      "default": 10
    },
    {
      "type": "number",
      "id": "tier_1_months",
      "label": "Tier 1 — Delivery every X months",
      "default": 1
    },
    {
      "type": "checkbox",
      "id": "tier_1_best",
      "label": "Tier 1 — Best Value badge",
      "default": false
    },
    {
      "type": "text",
      "id": "tier_1_selling_plan",
      "label": "Tier 1 — Selling Plan ID"
    },
    {
      "type": "text",
      "id": "tier_1_attr_key",
      "label": "Tier 1 — Hidden line item key",
      "info": "Prefix with _ to hide from checkout/cart (e.g. _bundle_tier)"
    },
    {
      "type": "text",
      "id": "tier_1_attr_value",
      "label": "Tier 1 — Hidden line item value"
    },
    {
      "type": "header",
      "content": "Tier 2"
    },
    {
      "type": "number",
      "id": "tier_2_qty",
      "label": "Tier 2 — Bottles",
      "default": 2
    },
    {
      "type": "number",
      "id": "tier_2_free",
      "label": "Tier 2 — Free bottles (from qty)",
      "default": 1
    },
    {
      "type": "number",
      "id": "tier_2_save",
      "label": "Tier 2 — Subscribe extra discount %",
      "default": 10
    },
    {
      "type": "number",
      "id": "tier_2_months",
      "label": "Tier 2 — Delivery every X months",
      "default": 2
    },
    {
      "type": "checkbox",
      "id": "tier_2_best",
      "label": "Tier 2 — Best Value badge",
      "default": false
    },
    {
      "type": "text",
      "id": "tier_2_selling_plan",
      "label": "Tier 2 — Selling Plan ID"
    },
    {
      "type": "text",
      "id": "tier_2_attr_key",
      "label": "Tier 2 — Hidden line item key",
      "info": "Prefix with _ to hide from checkout/cart (e.g. _bundle_tier)"
    },
    {
      "type": "text",
      "id": "tier_2_attr_value",
      "label": "Tier 2 — Hidden line item value"
    },
    {
      "type": "header",
      "content": "Tier 3"
    },
    {
      "type": "number",
      "id": "tier_3_qty",
      "label": "Tier 3 — Bottles",
      "default": 4
    },
    {
      "type": "number",
      "id": "tier_3_free",
      "label": "Tier 3 — Free bottles (from qty)",
      "default": 2
    },
    {
      "type": "number",
      "id": "tier_3_save",
      "label": "Tier 3 — Subscribe extra discount %",
      "default": 10
    },
    {
      "type": "number",
      "id": "tier_3_months",
      "label": "Tier 3 — Delivery every X months",
      "default": 4
    },
    {
      "type": "checkbox",
      "id": "tier_3_best",
      "label": "Tier 3 — Best Value badge",
      "default": true
    },
    {
      "type": "text",
      "id": "tier_3_selling_plan",
      "label": "Tier 3 — Selling Plan ID"
    },
    {
      "type": "text",
      "id": "tier_3_attr_key",
      "label": "Tier 3 — Hidden line item key",
      "info": "Prefix with _ to hide from checkout/cart (e.g. _bundle_tier)"
    },
    {
      "type": "text",
      "id": "tier_3_attr_value",
      "label": "Tier 3 — Hidden line item value"
    },
    {
      "type": "header",
      "content": "Shade Finder"
    },
    {
      "type": "url",
      "id": "find_shade_url",
      "label": "Find your shade link"
    },
    {
      "type": "header",
      "content": "Trust Badges (USPs)"
    },
    {
      "type": "paragraph",
      "content": "Each line is a stacked USP shown under the ATC button."
    },
    {
      "type": "text",
      "id": "trust_badge_1",
      "label": "USP 1",
      "default": "30-day money back guarantee"
    },
    {
      "type": "text",
      "id": "trust_badge_2",
      "label": "USP 2"
    },
    {
      "type": "text",
      "id": "trust_badge_3",
      "label": "USP 3"
    },
    {
      "type": "header",
      "content": "Post-ATC Upsell"
    },
    {
      "type": "paragraph",
      "content": "Product opened in the quickview sidebar after a successful add to cart. Leave empty to just open the cart drawer."
    },
    {
      "type": "product",
      "id": "bundle_post_atc_upsell",
      "label": "Upsell product"
    }
  ],
  "presets": [
    {
      "name": "Maison Bundle"
    }
  ]
}
{% endschema %}
