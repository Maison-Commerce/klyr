{
  "name": "Maison Bundle",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Low Stock"
    },
    {
      "type": "checkbox",
      "id": "show_low_stock",
      "label": "Show low stock indicator",
      "default": true
    },
    {
      "type": "text",
      "id": "low_stock_text",
      "label": "Low stock text",
      "default": "Low stock: Only few items left"
    },
    {
      "type": "header",
      "content": "Tabs"
    },
    {
      "type": "text",
      "id": "single_tab_label",
      "label": "Single purchase tab label",
      "default": "Single Purchase"
    },
    {
      "type": "text",
      "id": "subscribe_tab_label",
      "label": "Subscribe tab label",
      "default": "Subscribe & Save"
    },
    {
      "type": "number",
      "id": "save_percent",
      "label": "Save percentage badge",
      "default": 15
    },
    {
      "type": "header",
      "content": "Single Purchase"
    },
    {
      "type": "checkbox",
      "id": "show_single_tiers",
      "label": "Show quantity tiers (instead of BOGO card)",
      "default": false
    },
    {
      "type": "number",
      "id": "single_units",
      "label": "Number of units (quantity multiplier) — used when tiers are off",
      "default": 2
    },
    {
      "type": "text",
      "id": "bogo_badge_text",
      "label": "Badge text — used when tiers are off",
      "default": "BOGO SALE"
    },
    {
      "type": "header",
      "content": "Subscribe & Save"
    },
    {
      "type": "select",
      "id": "default_tab",
      "label": "Default active tab",
      "options": [
        { "value": "single", "label": "Single Purchase" },
        { "value": "subscribe", "label": "Subscribe & Save" }
      ],
      "default": "single"
    },
    {
      "type": "range",
      "id": "tier_count",
      "label": "Number of tiers",
      "min": 1,
      "max": 3,
      "step": 1,
      "default": 3
    },
    {
      "type": "header",
      "content": "Subscription Benefits"
    },
    {
      "type": "text",
      "id": "sub_benefit_1",
      "label": "Benefit 1",
      "default": "Save <strong>[save_percent]%<\/strong> on all deliveries",
      "info": "Use [save_percent] as placeholder for the save percentage. Supports HTML."
    },
    {
      "type": "text",
      "id": "sub_benefit_2",
      "label": "Benefit 2",
      "default": "No commitment - modify or cancel anytime"
    },
    {
      "type": "text",
      "id": "sub_benefit_3",
      "label": "Benefit 3",
      "default": "Free shipping, always"
    },
    {
      "type": "text",
      "id": "sub_benefit_4",
      "label": "Benefit 4",
      "default": "Out of stock protection for consistent result"
