{% comment %}
  This block holds settings for a subscription option row in the Maison Bundle.
  It renders nothing on its own — the maison-bundle snippet reads these blocks from section.blocks.
{% endcomment %}

{% schema %}
{
  "name": "Bundle Sub Option",
  "tag": null,
  "settings": [
    {
      "type": "number",
      "id": "quantity",
      "label": "Quantity (bottles)",
      "default": 1
    },
    {
      "type": "text",
      "id": "price_per_bottle",
      "label": "Price per bottle",
      "default": "50"
    },
    {
      "type": "text",
      "id": "compare_price_per_bottle",
      "label": "Compare at price per bottle",
      "default": "59"
    },
    {
      "type": "number",
      "id": "save_percent",
      "label": "Save percentage",
      "default": 15
    },
    {
      "type": "checkbox",
      "id": "best_value",
      "label": "Show 'Best Value' badge",
      "default": false
    },
    {
      "type": "number",
      "id": "delivery_months",
      "label": "Delivery frequency (months)",
      "default": 1
    }
  ],
  "presets": [
    {
      "name": "Bundle Sub Option"
    }
  ]
}
{% endschema %}
