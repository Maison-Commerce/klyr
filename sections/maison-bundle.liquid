    font-size: 12px;
    color: #999;
    margin-bottom: 24px;
  }

  /* Animation */
  @keyframes mb-fadeSlideIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .mb-animate-in {
    animation: mb-fadeSlideIn 0.35s ease forwards;
  }
</style>

