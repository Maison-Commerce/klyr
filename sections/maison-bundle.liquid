{%- liquid
  assign product_resource = section.settings.product | default: product
  assign save_percent = section.settings.save_percent | default: 15
  assign low_stock_text = section.settings.low_stock_text | default: 'Low stock: Only few items left'
  assign bogo_text = section.settings.bogo_badge_text | default: 'BOGO SALE'
  assign single_units = section.settings.single_units | default: 2
  assign single_compare_price = section.settings.single_compare_price
  assign single_price = section.settings.single_price
  assign cancel_note = section.settings.cancel_note | default: 'Cancel or modify anytime — no commitments'
  assign trust_1 = section.settings.trust_badge_1 | default: '30-day money back guarantee'
  assign trust_2 = section.settings.trust_badge_2 | default: 'Free shipping from $75'
  assign find_shade_url = section.settings.find_shade_url | default: '#open-quiz-tools/perfect-product-finder/discover-your-perfect-shade'
-%}

<script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>

<div
  class="maison-bundle section"
  x-data="maisonBundle()"
  x-cloak
  data-section-id="{{ section.id }}"
>
  <!-- Low Stock -->
  {% if section.settings.show_low_stock %}
    <div class="mb-low-stock">
      <span class="mb-low-stock__dot"></span>
      {{ low_stock_text }}
    </div>
  {% endif %}

  <!-- Purchase Type Tabs -->
  <div class="mb-tab-container">
    <div class="mb-tab-slider" :class="{ 'mb-tab-slider--right': tab === 'subscribe' }"></div>
    <button
      class="mb-tab-btn"
      :class="{ 'mb-tab-btn--active': tab === 'single' }"
      @click="switchTab('single')"
      type="button"
    >
      {{ section.settings.single_tab_label | default: 'Single Purchase' }}
    </button>
    <button
      class="mb-tab-btn"
      :class="{ 'mb-tab-btn--active': tab === 'subscribe' }"
      @click="switchTab('subscribe')"
      type="button"
    >
      {{ section.settings.subscribe_tab_label | default: 'Subscribe & Save' }}
      <span class="mb-tab-save-badge">SAVE {{ save_percent }}%</span>
    </button>
  </div>

  <!-- PANELS -->
  <div class="mb-panels-container">

    <!-- SINGLE PURCHASE PANEL -->
    <div class="mb-tab-panel" :class="{ 'mb-tab-panel--hidden': tab !== 'single' }">

      <!-- Quantity Card -->
      <div class="mb-qty-card mb-qty-card--selected">
        <div class="mb-qty-card__header">
          <span class="mb-qty-card__units">{{ single_units }} Units</span>
          {% if bogo_text != blank %}
            <span class="mb-bogo-badge">{{ bogo_text }}</span>
          {% endif %}
        </div>
        <div class="mb-qty-card__pricing">
          {% if single_compare_price %}
            <span class="mb-price-old">${{ single_compare_price }}</span>
          {% endif %}
          {% if single_price %}
            <span class="mb-price-new">${{ single_price }}</span>
          {% endif %}
        </div>
      </div>

      <!-- Shade selectors for single purchase -->
      {% for i in (1..single_units) %}
        <div class="mb-shade-row">
          <div class="mb-shade-label">
            <div>
              <span>
                {% if single_units > 1 %}
                  Shade {{ i }}:
                {% else %}
                  Shade:
                {% endif %}
              </span>
              <strong x-text="getVariantName(singleShades[{{ i | minus: 1 }}])"></strong>
            </div>
            {% if i == 1 and find_shade_url != blank %}
              <a class="mb-find-shade" href="{{ find_shade_url }}">Find your shade</a>
            {% endif %}
          </div>
          <div class="mb-swatches">
            <template x-for="(variant, idx) in variants" :key="'single-{{ i }}-' + idx">
              <div
                class="mb-swatch"
                :class="{ 'mb-swatch--selected': singleShades[{{ i | minus: 1 }}] === idx }"
                :style="'background:' + variant.swatchColor"
                @click="setSingleShade({{ i | minus: 1 }}, idx)"
              ></div>
            </template>
          </div>
        </div>
      {% endfor %}

      <form action="{{ routes.cart_add_url }}" method="post" @submit.prevent="addToCartSingle()">
        <button type="submit" class="mb-add-to-cart" :disabled="loading">
          <span x-show="!loading">ADD TO CART</span>
          <span x-show="loading">ADDING...</span>
        </button>
      </form>
    </div>

    <!-- SUBSCRIBE & SAVE PANEL -->
    <div class="mb-tab-panel" :class="{ 'mb-tab-panel--hidden': tab !== 'subscribe' }">

      <div class="mb-sub-section-label">Choose your quantity</div>
      <div class="mb-qty-selector">
        {% for block in section.blocks %}
          {% if block.type == 'sub_option' %}
            <div
              class="mb-qty-option"
              :class="{ 'mb-qty-option--selected': subQty === {{ forloop.index0 }} }"
              @click="selectSubQty({{ forloop.index0 }})"
            >
              <div class="mb-qty-option__left">
                <span class="mb-qty-option__text">
                  {{ block.settings.quantity }}
                  {% if block.settings.quantity == 1 %}bottle{% else %}bottles{% endif %}
                </span>
                {% if block.settings.save_percent > save_percent %}
                  <span class="mb-qty-option__save">Save {{ block.settings.save_percent }}%</span>
                {% endif %}
                {% if block.settings.best_value %}
                  <span class="mb-qty-option__best-value">Best Value</span>
                {% endif %}
              </div>
              <div class="mb-qty-option__right">
                {% if block.settings.compare_price_per_bottle %}
                  <span class="mb-qty-option__compare">${{ block.settings.compare_price_per_bottle }}</span>
                {% endif %}
                <span class="mb-qty-option__price">${{ block.settings.price_per_bottle }}</span>
                <span class="mb-qty-option__per">/bottle</span>
              </div>
            </div>
          {% endif %}
        {% endfor %}
      </div>

      <!-- Delivery Note -->
      <div class="mb-delivery-note">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
        </svg>
        <span>Delivered every <strong x-text="subOptions[subQty].deliveryMonths + (subOptions[subQty].deliveryMonths === 1 ? ' month' : ' months')"></strong></span>
      </div>

      <!-- Shade selectors for subscribe -->
      <template x-for="n in subOptions[subQty].qty" :key="'sub-shade-' + n">
        <div class="mb-shade-row mb-animate-in">
          <div class="mb-shade-label">
            <div>
              <span x-text="subOptions[subQty].qty > 1 ? 'Shade ' + n + ': ' : 'Shade: '"></span>
              <strong x-text="getVariantName(subShades[n - 1] ?? 0)"></strong>
            </div>
            <a class="mb-find-shade" x-show="n === 1" href="{{ find_shade_url }}">Find your shade</a>
          </div>
          <div class="mb-swatches">
            <template x-for="(variant, idx) in variants" :key="'sub-sw-' + n + '-' + idx">
              <div
                class="mb-swatch"
                :class="{ 'mb-swatch--selected': (subShades[n - 1] ?? 0) === idx }"
                :style="'background:' + variant.swatchColor"
                @click="setSubShade(n - 1, idx)"
              ></div>
            </template>
          </div>
        </div>
      </template>

      <p class="mb-cancel-note">{{ cancel_note }}</p>

      <form action="{{ routes.cart_add_url }}" method="post" @submit.prevent="addToCartSubscribe()">
        <button type="submit" class="mb-add-to-cart" :disabled="loading">
          <span x-show="!loading">ADD TO CART</span>
          <span x-show="loading">ADDING...</span>
        </button>
      </form>
    </div>

  </div>

  <!-- Trust Badges -->
  {% if trust_1 != blank or trust_2 != blank %}
    <div class="mb-trust-badges">
      {% if trust_1 != blank %}
        <div class="mb-trust-badge">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#555" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M23 4l-6 6-3-3"/>
            <path d="M20 12v6a2 2 0 01-2 2H6a2 2 0 01-2-2V6a2 2 0 012-2h9"/>
          </svg>
          {{ trust_1 }}
        </div>
      {% endif %}
      {% if trust_2 != blank %}
        <div class="mb-trust-badge">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#555" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <rect x="1" y="3" width="15" height="13" rx="2"/>
            <path d="M16 8h4l3 3v5a2 2 0 01-2 2h-1"/>
            <circle cx="5.5" cy="18.5" r="2.5"/>
            <circle cx="18.5" cy="18.5" r="2.5"/>
          </svg>
          {{ trust_2 }}
        </div>
      {% endif %}
    </div>
  {% endif %}
</div>

<script>
  function maisonBundle() {
    const productData = {{ product_resource | json }};
    const sellingPlanId = {{ section.settings.selling_plan_id | default: 'null' | json }};
    const cartAddUrl = '{{ routes.cart_add_url | append: ".js" }}';

    // Build variants array from the product
    const variants = productData.variants.map(v => {
      // Try to extract swatch color from option values or featured image
      let swatchColor = '#ccc';
      if (v.option1) {
        // Use metafield swatch colors if available, otherwise fallback
        swatchColor = v.featured_image ? `url(${v.featured_image.src})` : '#ccc';
      }
      return {
        id: v.id,
        title: v.title,
        name: v.option1 || v.title,
        available: v.available,
        price: v.price,
        compareAtPrice: v.compare_at_price,
        swatchColor: swatchColor,
        featuredImage: v.featured_image
      };
    });

    // Override swatch colors from Shopify color swatches if available
    {%- for variant in product_resource.variants -%}
      {%- assign swatch = variant.option1 | handleize -%}
      {%- for option in product_resource.options_with_values -%}
        {%- if forloop.first -%}
          {%- for val in option.values -%}
            {%- if val.swatch.color -%}
    if (variants[{{ forloop.index0 }}]) {
      variants[{{ forloop.index0 }}].swatchColor = 'rgb({{ val.swatch.color.rgb }})';
    }
            {%- elsif val.swatch.image -%}
    if (variants[{{ forloop.index0 }}]) {
      variants[{{ forloop.index0 }}].swatchColor = 'url({{ val.swatch.image | image_url: width: 80 }})';
    }
            {%- endif -%}
          {%- endfor -%}
          {%- break -%}
        {%- endif -%}
      {%- endfor -%}
      {%- break -%}
    {%- endfor -%}

    // Build sub options from blocks
    const subOptions = [
      {%- for block in section.blocks -%}
        {%- if block.type == 'sub_option' -%}
          {
            qty: {{ block.settings.quantity }},
            pricePerBottle: {{ block.settings.price_per_bottle }},
            originalPerBottle: {{ block.settings.compare_price_per_bottle | default: block.settings.price_per_bottle }},
            save: {{ block.settings.save_percent | default: 0 }},
            best: {{ block.settings.best_value | json }},
            deliveryMonths: {{ block.settings.delivery_months | default: 1 }}
          },
        {%- endif -%}
      {%- endfor -%}
    ];

    return {
      tab: 'single',
      loading: false,
      variants: variants,
      subOptions: subOptions.length > 0 ? subOptions : [{ qty: 1, pricePerBottle: 50, originalPerBottle: 59, save: 15, best: false, deliveryMonths: 1 }],

      // Single purchase
      singleShades: Array.from({ length: {{ single_units }} }, (_, i) => Math.min(i, variants.length - 1)),

      // Subscribe
      subQty: 0,
      subShades: [0, 1, 2, 3],

      switchTab(t) {
        this.tab = t;
      },

      getVariantName(index) {
        return this.variants[index]?.name || '';
      },

      setSingleShade(index, value) {
        this.singleShades[index] = value;
        this.singleShades = [...this.singleShades];
      },

      selectSubQty(i) {
        this.subQty = i;
      },

      setSubShade(index, value) {
        this.subShades[index] = value;
        this.subShades = [...this.subShades];
      },

      async addToCartSingle() {
        if (this.loading) return;
        this.loading = true;

        try {
          const items = this.singleShades.map(shadeIdx => ({
            id: this.variants[shadeIdx].id,
            quantity: 1
          }));

          // Combine duplicate variant IDs
          const combined = {};
          items.forEach(item => {
            combined[item.id] = (combined[item.id] || 0) + item.quantity;
          });

          const payload = {
            items: Object.entries(combined).map(([id, quantity]) => ({
              id: parseInt(id),
              quantity
            }))
          };

          const res = await fetch(cartAddUrl, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload)
          });

          if (!res.ok) throw new Error('Failed to add to cart');

          // Dispatch cart update event
          document.dispatchEvent(new CustomEvent('cart:updated'));
          window.location.href = '{{ routes.cart_url }}';
        } catch (e) {
          console.error('Add to cart error:', e);
        } finally {
          this.loading = false;
        }
      },

      async addToCartSubscribe() {
        if (this.loading) return;
        this.loading = true;

        try {
          const qty = this.subOptions[this.subQty].qty;
          const shades = this.subShades.slice(0, qty);

          const items = shades.map(shadeIdx => {
            const item = {
              id: this.variants[shadeIdx].id,
              quantity: 1
            };
            if (sellingPlanId) {
              item.selling_plan = sellingPlanId;
            }
            return item;
          });

          // Combine duplicate variant IDs
          const combined = {};
          items.forEach(item => {
            const key = item.id;
            if (!combined[key]) {
              combined[key] = { ...item };
            } else {
              combined[key].quantity += item.quantity;
            }
          });

          const payload = {
            items: Object.values(combined)
          };

          const res = await fetch(cartAddUrl, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload)
          });

          if (!res.ok) throw new Error('Failed to add to cart');

          document.dispatchEvent(new CustomEvent('cart:updated'));
          window.location.href = '{{ routes.cart_url }}';
        } catch (e) {
          console.error('Add to cart error:', e);
        } finally {
          this.loading = false;
        }
      }
    };
  }
</script>

<style>
  [x-cloak] { display: none !important; }

  .maison-bundle {
    max-width: 540px;
    margin: 0 auto;
    padding: 0 20px;
    font-family: var(--font-paragraph--family), sans-serif;
    color: #1a1a1a;
    -webkit-font-smoothing: antialiased;
  }

  /* Low Stock */
  .mb-low-stock {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 14px;
    color: #555;
    margin-bottom: 24px;
  }
  .mb-low-stock__dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: #e8a030;
    flex-shrink: 0;
  }

  /* Tabs */
  .mb-tab-container {
    display: flex;
    border: 1.5px solid #e0e0e0;
    border-radius: 10px;
    overflow: hidden;
    margin-bottom: 28px;
    position: relative;
    background: #fafafa;
  }
  .mb-tab-btn {
    flex: 1;
    padding: 16px 12px;
    font-family: var(--font-paragraph--family), sans-serif;
    font-size: 14px;
    font-weight: 500;
    text-align: center;
    cursor: pointer;
    border: none;
    background: transparent;
    color: #777;
    position: relative;
    z-index: 1;
    transition: color 0.3s ease;
    line-height: 1.3;
  }
  .mb-tab-btn--active {
    color: #1a1a1a;
    font-weight: 600;
  }
  .mb-tab-slider {
    position: absolute;
    top: 3px;
    left: 3px;
    width: calc(50% - 3px);
    height: calc(100% - 6px);
    background: #fff;
    border-radius: 8px;
    box-shadow: 0 1px 4px rgba(0,0,0,0.1);
    transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    z-index: 0;
  }
  .mb-tab-slider--right {
    transform: translateX(100%);
  }
  .mb-tab-save-badge {
    display: inline-block;
    background: #b8232a;
    color: #fff;
    font-size: 10px;
    font-weight: 700;
    padding: 2px 6px;
    border-radius: 3px;
    margin-left: 4px;
    letter-spacing: 0.3px;
    vertical-align: middle;
    position: relative;
    top: -1px;
  }

  /* Panels */
  .mb-panels-container {
    position: relative;
  }
  .mb-tab-panel {
    transition: opacity 0.3s ease, visibility 0.3s ease, transform 0.3s ease;
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }
  .mb-tab-panel--hidden {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    opacity: 0;
    visibility: hidden;
    transform: translateY(6px);
    pointer-events: none;
  }

  /* Single Purchase Qty Card */
  .mb-qty-card {
    border: 1.5px solid #e0e0e0;
    border-radius: 10px;
    padding: 16px 18px;
    margin-bottom: 28px;
    cursor: pointer;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }
  .mb-qty-card:hover {
    border-color: #ccc;
  }
  .mb-qty-card--selected {
    border-color: #1a1a1a;
    box-shadow: 0 0 0 1px #1a1a1a;
  }
  .mb-qty-card__header {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 4px;
  }
  .mb-qty-card__units {
    font-size: 16px;
    font-weight: 500;
  }
  .mb-bogo-badge {
    background: #b8232a;
    color: #fff;
    font-size: 11px;
    font-weight: 700;
    padding: 2px 8px;
    border-radius: 3px;
    letter-spacing: 0.3px;
  }
  .mb-qty-card__pricing {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .mb-price-old {
    font-size: 15px;
    color: #999;
    text-decoration: line-through;
  }
  .mb-price-new {
    font-size: 17px;
    font-weight: 700;
    color: #b8232a;
  }

  /* Subscribe Section */
  .mb-sub-section-label {
    font-size: 13px;
    color: #777;
    font-weight: 500;
    margin-bottom: 10px;
    letter-spacing: 0.2px;
  }
  .mb-qty-selector {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-bottom: 20px;
  }
  .mb-qty-option {
    display: flex;
    align-items: center;
    justify-content: space-between;
    border: 1.5px solid #e0e0e0;
    border-radius: 8px;
    padding: 12px 14px;
    cursor: pointer;
    transition: all 0.25s ease;
    background: #fff;
    position: relative;
    overflow: hidden;
  }
  .mb-qty-option:hover {
    border-color: #bbb;
  }
  .mb-qty-option--selected {
    border-color: #1a1a1a;
    box-shadow: 0 0 0 1px #1a1a1a;
  }
  .mb-qty-option__left {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .mb-qty-option__text {
    font-size: 14px;
    font-weight: 600;
    color: #1a1a1a;
  }
  .mb-qty-option__save {
    font-size: 10px;
    font-weight: 700;
    color: #b8232a;
    background: #fef2f2;
    padding: 2px 6px;
    border-radius: 3px;
  }
  .mb-qty-option__best-value {
    font-size: 9px;
    font-weight: 700;
    color: #fff;
    background: #1a1a1a;
    padding: 2px 6px;
    border-radius: 3px;
    letter-spacing: 0.3px;
    text-transform: uppercase;
  }
  .mb-qty-option__right {
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .mb-qty-option__compare {
    font-size: 12px;
    color: #999;
    text-decoration: line-through;
    font-weight: 500;
  }
  .mb-qty-option__price {
    font-size: 14px;
    font-weight: 700;
    color: #1a1a1a;
  }
  .mb-qty-option__per {
    font-size: 11px;
    color: #888;
    font-weight: 500;
  }

  /* Delivery Note */
  .mb-delivery-note {
    font-size: 13px;
    color: #777;
    margin-bottom: 28px;
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .mb-delivery-note svg { flex-shrink: 0; }
  .mb-delivery-note strong { font-weight: 600; color: #555; }

  /* Shade Selectors */
  .mb-shade-row { margin-bottom: 24px; }
  .mb-shade-label {
    font-size: 14px;
    color: #1a1a1a;
    margin-bottom: 10px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .mb-shade-label span { font-weight: 400; }
  .mb-shade-label strong { font-weight: 700; }
  .mb-find-shade {
    font-size: 14px;
    color: #1a1a1a;
    text-decoration: underline;
    text-underline-offset: 3px;
    cursor: pointer;
    font-weight: 500;
  }
  .mb-swatches {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }
  .mb-swatch {
    width: 44px;
    height: 44px;
    border-radius: 6px;
    cursor: pointer;
    border: 2px solid transparent;
    transition: border-color 0.2s ease, transform 0.15s ease;
    position: relative;
    background-size: cover;
    background-position: center;
  }
  .mb-swatch:hover { transform: scale(1.08); }
  .mb-swatch--selected { border-color: #1a1a1a; }

  /* Add to Cart */
  .mb-add-to-cart {
    width: 100%;
    background: #1a1a1a;
    color: #fff;
    border: none;
    border-radius: 10px;
    padding: 20px;
    font-family: var(--font-paragraph--family), sans-serif;
    font-size: 15px;
    font-weight: 600;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    cursor: pointer;
    transition: background 0.2s ease, transform 0.15s ease;
    margin-bottom: 20px;
  }
  .mb-add-to-cart:hover { background: #333; }
  .mb-add-to-cart:active { transform: scale(0.985); }
  .mb-add-to-cart:disabled { opacity: 0.7; cursor: not-allowed; }

  /* Trust Badges */
  .mb-trust-badges {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    margin-bottom: 32px;
  }
  .mb-trust-badge {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 14px;
    color: #555;
  }
  .mb-trust-badge svg { flex-shrink: 0; }

  /* Cancel Note */
